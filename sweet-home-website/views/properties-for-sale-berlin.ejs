<% useMainContainer = false %>
<% useHomeHeader = true %>
<link rel="stylesheet" href="/css/home.css" />
<link rel="stylesheet" href="/css/berlin-landing.min.css?v=20260326-3" />

<div id="locations-data" data-locations='<%- (typeof minifyJSON !== 'undefined' ? minifyJSON(locations) : JSON.stringify(locations)).replace(/'/g, '&#39;') %>' data-neighborhood-counts='<%- (typeof minifyJSON !== 'undefined' ? minifyJSON(typeof neighborhoodCounts !== 'undefined' && neighborhoodCounts ? neighborhoodCounts : {}) : JSON.stringify(typeof neighborhoodCounts !== 'undefined' && neighborhoodCounts ? neighborhoodCounts : {})).replace(/'/g, '&#39;') %>' style="display:none"></div>

<div class="berlin-landing-page">
  <!-- 1) Hero: title, description, CTA -->
  <section class="berlin-hero" aria-labelledby="berlin-hero-title">
    <div class="berlin-hero__bg">
      <img src="/images/berlin-hero.jpg" alt="<%= t('berlin.heroImgAlt','Berlin skyline – properties for sale in Berlin, Germany') %>" fetchpriority="high" decoding="async">
    </div>
    <div class="berlin-hero__overlay"></div>
    <div class="berlin-hero__content">
      <h1 id="berlin-hero-title" class="berlin-hero__title"><%= t('berlin.heroTitle','Properties for Sale in Berlin') %></h1>
      <p class="berlin-hero__description"><%= t('berlin.heroDescription','Discover carefully selected properties for sale in Berlin, one of Europe\'s most attractive real estate markets. Sweet Home supports international buyers and investors with expert guidance and access to residential and investment opportunities across the city.') %></p>
    </div>
  </section>

  <!-- 2) Search bar section (Germany default) -->
  <section id="berlin-search" class="berlin-search" aria-labelledby="berlin-search-title">
    <h2 id="berlin-search-title" class="berlin-search__title sr-only"><%= t('home.search.cta','Search Properties') %></h2>
    <form action="<%= (typeof localePath === 'function') ? localePath('/properties') : '/properties' %>" method="get" class="berlin-search__form">
      <div class="berlin-search__row">
        <label class="sr-only" for="country"><%= t('forms.country','Country') %></label>
        <select id="country" name="country" aria-label="<%= t('forms.country','Country') %>">
          <option value=""><%= t('forms.country','Country') %></option>
          <% Object.keys(locations).forEach(c => { %>
            <option value="<%= c %>" <%= c === 'Germany' ? 'selected' : '' %>><%= c %></option>
          <% }); %>
        </select>
        <label class="sr-only" for="city"><%= t('forms.city','City') %></label>
        <select id="city" name="city" aria-label="<%= t('forms.city','City') %>">
          <option value=""><%= t('forms.city','City') %></option>
          <% if (locations.Germany) { Object.keys(locations.Germany).forEach(ct => { %>
            <option value="<%= ct %>" <%= ct === 'Berlin' ? 'selected' : '' %>><%= ct %></option>
          <% }); } %>
        </select>
        <label class="sr-only" for="neighborhood"><%= t('forms.neighborhood','Neighborhood') %></label>
        <select id="neighborhood" name="neighborhood" disabled aria-label="<%= t('forms.neighborhood','Neighborhood') %>">
          <option value=""><%= t('forms.neighborhood','Neighborhood') %></option>
        </select>
        <label class="sr-only" for="operation"><%= t('forms.operation','Operation') %></label>
        <select id="operation" name="operation">
          <option value=""><%= t('forms.anyOperation','Any Operation') %></option>
          <option value="buy" selected><%= t('forms.operations.buy','Buy') %></option>
          <option value="rent"><%= t('forms.operations.rent','Rent') %></option>
        </select>
        <label class="sr-only" for="type"><%= t('forms.propertyType','Property Type') %></label>
        <select id="type" name="type">
          <option value=""><%= t('forms.anyType','Any Type') %></option>
          <option><%= t('forms.types.apartment','Apartment') %></option>
          <option><%= t('forms.types.house','House') %></option>
          <option><%= t('forms.types.villa','Villa') %></option>
          <option><%= t('forms.types.land','Land') %></option>
        </select>
        <button type="submit"><%= t('home.search.cta','Search Properties') %></button>
      </div>
    </form>
  </section>

  <!-- 3) Featured properties: 3x3 grid, handpicked style -->
  <section class="section featured berlin-featured" aria-labelledby="recommended-heading">
    <h2 id="recommended-heading" class="berlin-featured__title"><%= t('berlin.featuredTitle','Featured properties') %></h2>
    <div class="berlin-featured__grid" id="berlinRecommended">
      <% (recommendedProperties || []).forEach(property => { %>
        <%
          const photoUrl = (property.photos && property.photos[0]) ? property.photos[0] : '/img/property-placeholder.jpg';
          const size = property.size ? `${property.size} m²` : null;
          const beds = (typeof property.rooms !== 'undefined' && property.rooms !== null) ? property.rooms : null;
          const baths = (typeof property.bathrooms !== 'undefined' && property.bathrooms !== null) ? property.bathrooms : null;
          const numberLocale = lang === 'de' ? 'de-DE' : (lang === 'es' ? 'es-ES' : 'en-US');
          const priceText = property.price && Number(property.price) > 0 ? '€' + Number(property.price).toLocaleString(numberLocale) : '';
        %>
        <article class="property-card">
          <a href="<%= (typeof localePath === 'function') ? localePath('/properties/' + property.slug) : '/properties/' + property.slug %>" class="property-card-link">
            <div class="img-wrap" <%= priceText ? `data-price="${priceText}"` : '' %>>
              <img src="<%= photoUrl %>" alt="<%= property.title %>" loading="lazy" decoding="async" onerror="this.src='/img/property-placeholder.jpg'">
            </div>
            <div class="meta">
              <div class="title"><%= property.title %></div>
              <% if (priceText) { %><div class="price"><%= priceText %></div><% } %>
              <div class="location">
                <span class="icon icon-16 icon-inline icon-mask icon-location" style="color: currentColor;"></span>
                <%= property.neighborhood || property.city %>, <%= property.country %>
              </div>
              <div class="features-row">
                <% if (size) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-size"></span>
                    <span><%= size %></span>
                  </div>
                <% } %>
                <% if (beds !== null) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-bed"></span>
                    <span><%= beds %> bed<%= Number(beds) === 1 ? '' : 's' %></span>
                  </div>
                <% } %>
                <% if (baths !== null) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-bath"></span>
                    <span><%= baths %> bath<%= Number(baths) === 1 ? '' : 's' %></span>
                  </div>
                <% } %>
              </div>
              <span class="learn-more"><%= t('properties.list.viewDetails','View details') %> →</span>
            </div>
          </a>
        </article>
      <% }); %>
    </div>
    <% if (!recommendedProperties || recommendedProperties.length === 0) { %>
      <p class="section-empty"><%= t('properties.list.noResults','No properties found.') %> <a href="<%= (typeof localePath === 'function') ? localePath('/properties') : '/properties' %>?country=Germany"><%= t('home.search.cta','Search Properties') %></a></p>
    <% } else { %>
      <p class="section-cta">
        <a href="<%= (typeof localePath === 'function') ? localePath('/properties') : '/properties' %>?country=Germany" class="btn btn-primary"><%= t('berlin.viewAll','View all properties in Berlin') %></a>
      </p>
    <% } %>
  </section>

  <!-- 3a) New developments in Berlin -->
  <section class="section featured berlin-featured" aria-labelledby="berlin-projects-heading">
    <h2 id="berlin-projects-heading" class="berlin-featured__title"><%= t('berlin.newDevelopmentsTitle','New developments in Berlin') %></h2>
    <div class="berlin-featured__grid" id="berlinProjectsGrid">
      <% (berlinProjects || []).forEach(project => { %>
        <%
          const photoUrl = (project.photos && project.photos[0]) ? project.photos[0] : '/img/project-placeholder.jpg';
          const numberLocale = lang === 'de' ? 'de-DE' : (lang === 'es' ? 'es-ES' : 'en-US');
          const fromPrice = project.min_price && Number(project.min_price) > 0
            ? '€' + Number(project.min_price).toLocaleString(numberLocale)
            : '';
          const completionYear = project.completion_date ? new Date(project.completion_date).getFullYear() : null;
          const cityLabel = (typeof translateLocation === 'function') ? translateLocation('city', project.city) : project.city;
          const countryLabel = (typeof translateLocation === 'function') ? translateLocation('country', project.country) : project.country;
        %>
        <article class="property-card">
          <a href="<%= (typeof localePath === 'function') ? localePath('/projects/' + project.slug) : '/projects/' + project.slug %>" class="property-card-link">
            <div class="img-wrap" <%= fromPrice ? `data-price="${t('home.newDevelopment.fromPrice','From')} ${fromPrice}"` : '' %>>
              <img src="<%= photoUrl %>" alt="<%= project.title %>" loading="lazy" decoding="async" onerror="this.src='/img/project-placeholder.jpg'">
            </div>
            <div class="meta">
              <div class="title"><%= project.title %></div>
              <% if (fromPrice) { %>
                <div class="price"><%= t('home.newDevelopment.fromPrice','From') %> <%= fromPrice %></div>
              <% } %>
              <div class="location">
                <span class="icon icon-16 icon-inline icon-mask icon-location" style="color: currentColor;"></span>
                <%= cityLabel %>, <%= countryLabel %>
              </div>
              <div class="features-row">
                <% if (project.total_units) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-size"></span>
                    <span><%= project.total_units %> <%= t('home.newDevelopment.units','units') %></span>
                  </div>
                <% } %>
                <% if (completionYear) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-bath"></span>
                    <span><%= t('home.newDevelopment.completion','Completion') %> <%= completionYear %></span>
                  </div>
                <% } %>
              </div>
              <span class="learn-more"><%= t('home.recommendedProject.viewProject','View project') %> →</span>
            </div>
          </a>
        </article>
      <% }); %>
    </div>
    <% if (!berlinProjects || berlinProjects.length === 0) { %>
      <p class="section-empty"><%= t('home.newDevelopment.empty','No developments available right now.') %></p>
    <% } else { %>
      <p class="section-cta">
        <a href="<%= ((typeof localePath === 'function') ? localePath('/projects') : '/projects') %>?country=Germany&city=Berlin" class="btn btn-primary"><%= t('berlin.viewAllProjects','See all projects in Berlin') %></a>
      </p>
    <% } %>
  </section>

  <!-- 3b) Neighborhoods grid with expandable cards -->
  <section class="section berlin-neighborhoods" aria-labelledby="berlin-neighborhoods-heading">
    <h2 id="berlin-neighborhoods-heading" class="berlin-neighborhoods__title"><%= berlinContent.neighborhoodsTitle %></h2>
    <p class="berlin-neighborhoods__hint"><%= berlinContent.neighborhoodsHint %></p>
    <div class="berlin-neighborhoods__grid">
      <% (berlinNeighborhoods || []).forEach(function(item, idx){ %>
        <% const panelId = `berlin-neighborhood-panel-${idx}`; %>
        <% const buttonId = `berlin-neighborhood-trigger-${idx}`; %>
        <% const baseNeighborhoodPath = (typeof localePath === 'function') ? localePath('/properties/for-sale/germany/berlin') : '/properties/for-sale/germany/berlin'; %>
        <% const normalizedNeighborhood = String(item.name || '').toLowerCase(); %>
        <% let germanDistrictPath = ''; %>
        <% if (normalizedNeighborhood.indexOf('charlottenburg') !== -1) germanDistrictPath = '/wohnung-kaufen-charlottenburg'; %>
        <% if (normalizedNeighborhood === 'moabit') germanDistrictPath = '/wohnung-kaufen-moabit'; %>
        <% if (normalizedNeighborhood.indexOf('friedrichshain-kreuzberg') !== -1) germanDistrictPath = '/wohnung-kaufen-friedrichshain-kreuzberg'; %>
        <% if (normalizedNeighborhood.indexOf('schöneberg') !== -1 || normalizedNeighborhood.indexOf('schoneberg') !== -1) germanDistrictPath = '/wohnung-kaufen-schoeneberg'; %>
        <% if (normalizedNeighborhood.indexOf('prenzlauer berg') !== -1) germanDistrictPath = '/wohnung-kaufen-prenzlauer-berg'; %>
        <% if (normalizedNeighborhood.indexOf('wedding') !== -1) germanDistrictPath = '/wohnung-kaufen-wedding'; %>
        <% if (normalizedNeighborhood.indexOf('tempelhof') !== -1) germanDistrictPath = '/wohnung-kaufen-tempelhof'; %>
        <% if (normalizedNeighborhood.indexOf('neukölln') !== -1 || normalizedNeighborhood.indexOf('neukolln') !== -1) germanDistrictPath = '/wohnung-kaufen-neukoelln'; %>
        <% if (normalizedNeighborhood.indexOf('reinickendorf') !== -1) germanDistrictPath = '/wohnung-kaufen-reinickendorf'; %>
        <% if (normalizedNeighborhood === 'kreuzberg') germanDistrictPath = '/wohnung-kaufen-kreuzberg'; %>
        <% if (normalizedNeighborhood.indexOf('spandau') !== -1) germanDistrictPath = '/wohnung-kaufen-spandau'; %>
        <% const neighborhoodHref = (lang === 'de' && germanDistrictPath)
          ? germanDistrictPath
          : `${baseNeighborhoodPath}?neighborhood=${encodeURIComponent(item.name)}`; %>
        <% const neighborhoodCta = (berlinContent.neighborhoodsExploreCta || 'Explore properties in {name}').replace('{name}', item.name); %>
        <article class="berlin-neighborhood-card" data-neighborhood-card>
          <button
            type="button"
            id="<%= buttonId %>"
            class="berlin-neighborhood-card__trigger"
            data-neighborhood-toggle
            aria-expanded="false"
            aria-controls="<%= panelId %>"
          >
            <span class="berlin-neighborhood-card__name"><%= item.name %></span>
            <span class="berlin-neighborhood-card__icon" aria-hidden="true"></span>
          </button>
          <div class="berlin-neighborhood-card__panel" id="<%= panelId %>" role="region" aria-labelledby="<%= buttonId %>" hidden>
            <p><%= item.summary %></p>
            <p><strong><%= berlinContent.neighborhoodsRealEstateLabel %>:</strong> <%= item.realEstate %></p>
          </div>
          <a class="berlin-neighborhood-card__cta" data-neighborhood-cta href="<%= neighborhoodHref %>"><%= neighborhoodCta %></a>
        </article>
      <% }); %>
    </div>
    <p class="berlin-neighborhoods__source">
      <%= berlinContent.neighborhoodsSourcesLabel %>:
      <a href="https://www.berlin.de/special/stadtteile/uebersicht-nach-bezirken/" target="_blank" rel="noopener noreferrer">Berlin.de Stadtteile</a>,
      <a href="https://www.ibb.de/de/ueber-uns/publikationen/wohnungsmarktbericht/2024.html" target="_blank" rel="noopener noreferrer">IBB Wohnungsmarktbericht 2024</a>,
      <a href="https://www.berlinhyp.de/en/publications/details/housing-market-report-berlin-2025" target="_blank" rel="noopener noreferrer">Berlin Hyp &amp; CBRE 2025</a>.
    </p>
  </section>

  <section class="berlin-content section berlin-best-areas" aria-labelledby="berlin-internal-links-heading">
    <div class="berlin-content__inner">
      <% const berlinHubPath = (typeof localePath === 'function') ? localePath('/properties-for-sale-berlin') : '/properties-for-sale-berlin'; %>
      <% const berlinSearchPath = (typeof localePath === 'function') ? localePath('/properties/for-sale/germany/berlin') : '/properties/for-sale/germany/berlin'; %>
      <% if (lang === 'de') { %>
        <h2 id="berlin-internal-links-heading" class="berlin-content__title">Berlin Stadtteile: Weitere Immobilienseiten entdecken</h2>
        <p class="berlin-content__intro">Für eine schnelle Standortanalyse finden Sie hier unsere wichtigsten Berlin-Immobilienseiten mit direktem Einstieg in jeden Bezirk.</p>
        <ul class="berlin-areas__list">
          <li class="berlin-areas__item"><a href="/wohnungen-berlin-kaufen">Wohnungen in Berlin kaufen (Hauptseite)</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-charlottenburg">Wohnung kaufen Charlottenburg</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-moabit">Wohnung kaufen Moabit</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-friedrichshain-kreuzberg">Wohnung kaufen Friedrichshain-Kreuzberg</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-schoeneberg">Wohnung kaufen Schöneberg</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-prenzlauer-berg">Wohnung kaufen Prenzlauer Berg</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-wedding">Wohnung kaufen Wedding</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-tempelhof">Wohnung kaufen Tempelhof</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-neukoelln">Wohnung kaufen Neukölln</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-reinickendorf">Wohnung kaufen Reinickendorf</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-kreuzberg">Wohnung kaufen Kreuzberg</a></li>
          <li class="berlin-areas__item"><a href="/wohnung-kaufen-spandau">Wohnung kaufen Spandau</a></li>
        </ul>
        <p class="berlin-content__outro">Interne Verlinkung zwischen Hub und Stadtteilseiten verbessert die thematische Relevanz und hilft Suchmaschinen, die Seitenhierarchie klarer zu verstehen.</p>
      <% } else if (lang === 'es') { %>
        <h2 id="berlin-internal-links-heading" class="berlin-content__title">Zonas de Berlín: explorar propiedades por barrio</h2>
        <p class="berlin-content__intro">Estos enlaces ayudan a comparar barrios y encontrar propiedades en Berlín según presupuesto, estilo de vida y potencial de inversión.</p>
        <ul class="berlin-areas__list">
          <li class="berlin-areas__item"><a href="<%= berlinHubPath %>">Propiedades en venta en Berlín (página principal)</a></li>
          <% (berlinNeighborhoods || []).forEach(function(item){ %>
            <li class="berlin-areas__item"><a href="<%= berlinSearchPath %>?neighborhood=<%= encodeURIComponent(item.name) %>">Propiedades en <%= item.name %></a></li>
          <% }); %>
        </ul>
        <p class="berlin-content__outro">Una estructura interna clara entre página principal y resultados por barrio mejora la exploración del usuario y la interpretación temática para buscadores.</p>
      <% } else { %>
        <h2 id="berlin-internal-links-heading" class="berlin-content__title">Berlin Neighborhoods: Explore Properties by District</h2>
        <p class="berlin-content__intro">Use these links to compare neighborhoods and find Berlin apartments for sale by budget, lifestyle fit, and investment profile.</p>
        <ul class="berlin-areas__list">
          <li class="berlin-areas__item"><a href="<%= berlinHubPath %>">Apartments for Sale in Berlin (main page)</a></li>
          <% (berlinNeighborhoods || []).forEach(function(item){ %>
            <li class="berlin-areas__item"><a href="<%= berlinSearchPath %>?neighborhood=<%= encodeURIComponent(item.name) %>">Apartments in <%= item.name %> for sale</a></li>
          <% }); %>
        </ul>
        <p class="berlin-content__outro">This internal linking setup keeps the Berlin hub connected to district-level search paths without creating thin duplicate landing pages.</p>
      <% } %>
    </div>
  </section>

  <!-- 4) Why Invest in Berlin Real Estate (content by URL language) -->
  <section class="berlin-content section berlin-why-invest" aria-labelledby="berlin-why-invest-heading">
    <div class="berlin-content__inner">
      <h2 id="berlin-why-invest-heading" class="berlin-content__title"><%= berlinContent.whyInvestTitle %></h2>
      <div class="berlin-content__body">
        <p><%= berlinContent.whyInvestP1 %></p>
        <p><%= berlinContent.whyInvestP2 %></p>
      </div>
    </div>
  </section>

  <!-- 4b) Horizontal Berlin image break -->
  <section class="berlin-image-break" aria-hidden="true">
    <div class="berlin-image-break__wrap">
      <img src="/images/berlin-international.jpg" alt="" role="presentation" loading="lazy" decoding="async">
    </div>
  </section>

  <!-- 5) Best Areas to Buy Property in Berlin (content by URL language) -->
  <section class="berlin-content section berlin-best-areas" aria-labelledby="berlin-areas-heading">
    <div class="berlin-content__inner">
      <h2 id="berlin-areas-heading" class="berlin-content__title"><%= berlinContent.bestAreasTitle %></h2>
      <p class="berlin-content__intro"><%= berlinContent.bestAreasIntro %></p>
      <ul class="berlin-areas__list">
        <li class="berlin-areas__item"><strong>Mitte</strong> – <%= berlinContent.bestAreasMitte %></li>
        <li class="berlin-areas__item"><strong>Charlottenburg-Wilmersdorf</strong> – <%= berlinContent.bestAreasCharlottenburg %></li>
        <li class="berlin-areas__item"><strong>Pankow</strong> – <%= berlinContent.bestAreasPankow %></li>
        <li class="berlin-areas__item"><strong>Neukölln</strong> – <%= berlinContent.bestAreasNeukoelln %></li>
        <li class="berlin-areas__item"><strong>Lichtenberg &amp; Marzahn-Hellersdorf</strong> – <%= berlinContent.bestAreasLichtenberg %></li>
      </ul>
      <p class="berlin-content__outro"><%= berlinContent.bestAreasOutro %></p>
    </div>
  </section>

  <% if (lang === 'en') { %>
  <section class="berlin-content section berlin-buyer-playbook" aria-labelledby="berlin-buying-guide-heading">
    <div class="berlin-content__inner berlin-buyer-playbook__inner">
      <h2 id="berlin-buying-guide-heading" class="berlin-content__title">Buying an Apartment in Berlin: Costs, Timeline, and Next Steps</h2>
      <p class="berlin-content__intro">If you are evaluating Berlin apartments for sale, this section gives you a practical buyer framework: expected cost components, a realistic purchase timeline, and official legal/tax references to avoid unrealistic assumptions.</p>

      <div class="berlin-buyer-playbook__tabs" role="tablist" aria-label="Berlin apartment buying guide tabs">
        <button type="button" class="berlin-buyer-playbook__tab is-active" role="tab" aria-selected="true" aria-controls="berlin-playbook-costs" id="berlin-playbook-tab-costs" data-playbook-tab="costs">Cost Planner</button>
        <button type="button" class="berlin-buyer-playbook__tab" role="tab" aria-selected="false" aria-controls="berlin-playbook-timeline" id="berlin-playbook-tab-timeline" data-playbook-tab="timeline">Purchase Timeline</button>
      </div>

      <div class="berlin-buyer-playbook__panel is-active" id="berlin-playbook-costs" role="tabpanel" aria-labelledby="berlin-playbook-tab-costs" data-playbook-panel="costs">
        <div class="berlin-cost-planner">
          <div class="berlin-cost-planner__controls">
            <label for="berlin-cost-price">Purchase price (EUR)</label>
            <input id="berlin-cost-price" type="number" min="50000" step="1000" value="450000" data-cost-input="price">

            <label for="berlin-cost-notary">Notary + land register estimate (%)</label>
            <input id="berlin-cost-notary" type="number" min="0.5" max="3" step="0.1" value="1.5" data-cost-input="notary">

            <label for="berlin-cost-broker">Buyer-side broker share (%)</label>
            <input id="berlin-cost-broker" type="number" min="0" max="7" step="0.1" value="0" data-cost-input="broker">
          </div>
          <div class="berlin-cost-planner__results" aria-live="polite">
            <div class="berlin-cost-pill">
              <span>Purchase price</span>
              <strong id="berlin-cost-price-value">EUR 450,000</strong>
            </div>
            <div class="berlin-cost-pill">
              <span>Berlin transfer tax (6.0%)</span>
              <strong id="berlin-cost-tax-value">EUR 27,000</strong>
            </div>
            <div class="berlin-cost-pill">
              <span>Notary + land register</span>
              <strong id="berlin-cost-notary-value">EUR 6,750</strong>
            </div>
            <div class="berlin-cost-pill">
              <span>Buyer-side broker share</span>
              <strong id="berlin-cost-broker-value">EUR 0</strong>
            </div>
            <div class="berlin-cost-pill berlin-cost-pill--total">
              <span>Estimated total cash outlay</span>
              <strong id="berlin-cost-total-value">EUR 483,750</strong>
            </div>
          </div>
        </div>
        <div class="berlin-buyer-playbook__table-wrap">
          <table class="berlin-buyer-playbook__table">
            <thead>
              <tr>
                <th>Cost Component</th>
                <th>How to read it</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Grunderwerbsteuer (Berlin)</td>
                <td>Fixed at 6.0% of taxable consideration in Berlin.</td>
                <td><a href="https://service.berlin.de/dienstleistung/325323/" target="_blank" rel="noopener noreferrer">Service Berlin</a></td>
              </tr>
              <tr>
                <td>Notary requirement</td>
                <td>Property purchase agreements must be notarized to be legally valid.</td>
                <td><a href="https://www.gesetze-im-internet.de/bgb/__311b.html" target="_blank" rel="noopener noreferrer">Section 311b BGB</a></td>
              </tr>
              <tr>
                <td>Broker fee split</td>
                <td>Buyer-side broker share depends on contract setup and legal split rules.</td>
                <td><a href="https://www.gesetze-im-internet.de/bgb/__656c.html" target="_blank" rel="noopener noreferrer">Sections 656c/656d BGB</a></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="berlin-buyer-playbook__panel" id="berlin-playbook-timeline" role="tabpanel" aria-labelledby="berlin-playbook-tab-timeline" data-playbook-panel="timeline" hidden>
        <div class="berlin-timeline">
          <article class="berlin-timeline__step">
            <button type="button" class="berlin-timeline__trigger" data-timeline-toggle aria-expanded="false" aria-controls="timeline-step-1" id="timeline-step-btn-1">1) Shortlist and due diligence prep (typically 1-3 weeks)</button>
            <div class="berlin-timeline__content" id="timeline-step-1" role="region" aria-labelledby="timeline-step-btn-1" hidden>
              <p>Define budget, district priorities, and occupancy goals. Review building condition, maintenance history, and expected rental profile before legal drafting starts.</p>
            </div>
          </article>
          <article class="berlin-timeline__step">
            <button type="button" class="berlin-timeline__trigger" data-timeline-toggle aria-expanded="false" aria-controls="timeline-step-2" id="timeline-step-btn-2">2) Notary draft and signing (typically 2-4 weeks)</button>
            <div class="berlin-timeline__content" id="timeline-step-2" role="region" aria-labelledby="timeline-step-btn-2" hidden>
              <p>The notary prepares and explains the purchase contract, then records signatures. This is a mandatory legal step in Germany.</p>
            </div>
          </article>
          <article class="berlin-timeline__step">
            <button type="button" class="berlin-timeline__trigger" data-timeline-toggle aria-expanded="false" aria-controls="timeline-step-3" id="timeline-step-btn-3">3) Payment and filing sequence (typically 2-6 weeks)</button>
            <div class="berlin-timeline__content" id="timeline-step-3" role="region" aria-labelledby="timeline-step-btn-3" hidden>
              <p>After notary milestones are met, purchase funds are transferred. Tax clearance and registry processing are then coordinated with the relevant authorities.</p>
            </div>
          </article>
          <article class="berlin-timeline__step">
            <button type="button" class="berlin-timeline__trigger" data-timeline-toggle aria-expanded="false" aria-controls="timeline-step-4" id="timeline-step-btn-4">4) Ownership transfer and handover (typically 4-12+ weeks)</button>
            <div class="berlin-timeline__content" id="timeline-step-4" role="region" aria-labelledby="timeline-step-btn-4" hidden>
              <p>Final registration timing depends on authority workload and transaction specifics. Plan with a time buffer rather than a fixed promise date.</p>
            </div>
          </article>
        </div>
      </div>
      <p class="berlin-buyer-playbook__note">Indicative guidance only, not legal or tax advice. Always validate your case with your notary, tax advisor, and financing partner.</p>
      <p class="berlin-buyer-playbook__sources">Sources:
        <a href="https://service.berlin.de/dienstleistung/325323/" target="_blank" rel="noopener noreferrer">Service Berlin</a>,
        <a href="https://www.berlin.de/sen/finanzen/steuern/informationen-fuer-steuerzahler-/faq-steuern/artikel.9062.php" target="_blank" rel="noopener noreferrer">Berlin SenFin FAQ</a>,
        <a href="https://www.gesetze-im-internet.de/bgb/__311b.html" target="_blank" rel="noopener noreferrer">Section 311b BGB</a>,
        <a href="https://www.gesetze-im-internet.de/bgb/__656c.html" target="_blank" rel="noopener noreferrer">Sections 656c/656d BGB</a>,
        <a href="https://www.notar.de/aktuelles/details/immobilienkauf-nicht-ohne-notarin-oder-notar-komplikationen-beim-immobilienkauf-vermeiden" target="_blank" rel="noopener noreferrer">Notar.de</a>.
      </p>
    </div>
  </section>
  <% } %>

  <!-- 6) FAQ: Berlin real estate investment -->
  <section class="berlin-faq section" aria-labelledby="berlin-faq-heading">
    <h2 id="berlin-faq-heading" class="berlin-faq__title"><%= t('berlin.faqTitle','Frequently asked questions about buying property in Berlin') %></h2>
    <div class="berlin-faq__list">
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a1" id="berlin-faq-q1" data-faq-toggle>
            <%= t('berlin.faqQ1','Why should I consider investing in Berlin real estate?') %>
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a1" role="region" aria-labelledby="berlin-faq-q1" hidden>
          <p><%= t('berlin.faqA1','Berlin is one of Europe\'s most attractive real estate markets. The city has strong demographic growth, a robust economy, and ongoing demand for housing. According to the Berlin Housing Market Report 2025 (Berlin Hyp & CBRE), the capital needs around 222,000 new apartments by 2040, plus land provision for a further 50,000 units. Asking rents rose again in 2024 (by 12% to €15.79 per m² on average), making Berlin one of the top cities in Germany for rental dynamics. For investors, this combination of demand, limited supply, and rental growth supports long-term value and income potential.') %></p>
        </div>
      </article>
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a2" id="berlin-faq-q2" data-faq-toggle>
            <%= t('berlin.faqQ2','How have Berlin property prices developed recently?') %>
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a2" role="region" aria-labelledby="berlin-faq-q2" hidden>
          <p><%= t('berlin.faqA2','In 2024, asking prices for condominiums in Berlin decreased slightly by 0.9% to an average of €5,696 per m², while asking prices for apartment buildings fell by 4.4% to €3,041 per m². This reflects higher interest rates and economic uncertainty. At the same time, asking rents increased by 12% to €15.79 per m², with Berlin showing the highest rent dynamics among Germany\'s seven largest cities. So while purchase prices have corrected, rental income potential has strengthened, which can make Berlin attractive for buy-to-let and long-term investment.') %></p>
        </div>
      </article>
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a3" id="berlin-faq-q3" data-faq-toggle>
            <%= t('berlin.faqQ3','What is the long-term outlook for the Berlin housing market?') %>
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a3" role="region" aria-labelledby="berlin-faq-q3" hidden>
          <p><%= t('berlin.faqA3','Population forecasts assume growth of around 5% from 2021 to 2040, and the Urban Development Plan Housing 2040 targets 222,000 new apartments plus land for 50,000 more. The housing shortage remains a key challenge, which supports sustained demand. The institutional transaction market also recovered in 2024 (volume increased to €2.9 billion from €1.8 billion the previous year). Industry experts such as Berlin Hyp and CBRE indicate that if interest rates remain stable, a further slight increase in the transaction market can be expected in 2025, underlining continued investor interest in Berlin residential real estate.') %></p>
        </div>
      </article>
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a4" id="berlin-faq-q4" data-faq-toggle>
            <%= t('berlin.faqQ4','Where is new housing being built in Berlin?') %>
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a4" role="region" aria-labelledby="berlin-faq-q4" hidden>
          <p><%= t('berlin.faqA4','In 2024, around 215 construction projects with roughly 43,530 new apartments were in planning or construction—a significant increase compared to the previous year (34,940). Most large rental housing projects are concentrated outside the S-Bahn ring and in the Berlin metropolitan area; only about 14.6% of projects were within the ring, reflecting limited free land in the inner city. Districts such as Marzahn-Hellersdorf, Spandau, Pankow, and the metropolitan area (e.g. Potsdam, Barnim) are seeing substantial new development. Both state-owned housing companies and private developers are active, offering a mix of subsidised and market-rate housing and investment opportunities.') %></p>
        </div>
      </article>
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a5" id="berlin-faq-q5" data-faq-toggle>
            <%= t('berlin.faqQ5','Is now a good time to buy property in Berlin?') %>
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a5" role="region" aria-labelledby="berlin-faq-q5" hidden>
          <p><%= t('berlin.faqA5','Current conditions can be favourable for certain investors: purchase prices for condominiums and apartment buildings have adjusted from previous highs, while demand for housing and rental growth remain strong. The recalibration of the market to a new price level is seen as largely complete, and institutional interest in residential assets has increased again due to housing shortage and the resilience of the sector. Whether it\'s the right time for you depends on your goals, financing, and target area. Sweet Home can help you explore carefully selected properties and provide expert guidance for buying or investing in Berlin.') %></p>
        </div>
      </article>
      <% if (lang === 'en') { %>
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a6" id="berlin-faq-q6" data-faq-toggle>
            What should I know about buying apartment Berlin as an international buyer?
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a6" role="region" aria-labelledby="berlin-faq-q6" hidden>
          <p>Buying apartment Berlin usually starts with district selection, financing pre-check, and legal due diligence. International buyers should verify ownership structure, ancillary purchase costs, and occupancy status before signing. Working with a local advisor helps you compare listings faster and avoid overpriced micro-locations.</p>
        </div>
      </article>
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a7" id="berlin-faq-q7" data-faq-toggle>
            Where can I find Berlin flats for sale with strong rental potential?
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a7" role="region" aria-labelledby="berlin-faq-q7" hidden>
          <p>Berlin flats for sale with stable rental demand are commonly found in well-connected neighborhoods such as Moabit, Neukölln, Friedrichshain-Kreuzberg, and parts of Wedding. Focus on transport links, building condition, and realistic rent benchmarks rather than headline asking prices alone.</p>
        </div>
      </article>
      <article class="berlin-faq__item">
        <h3 class="berlin-faq__question">
          <button type="button" class="berlin-faq__trigger" aria-expanded="false" aria-controls="berlin-faq-a8" id="berlin-faq-q8" data-faq-toggle>
            Are Berlin flats for sale better for investment or owner-occupancy?
          </button>
        </h3>
        <div class="berlin-faq__answer" id="berlin-faq-a8" role="region" aria-labelledby="berlin-faq-q8" hidden>
          <p>Both can work. For investment, prioritize yield resilience, tenant demand, and building quality. For owner-occupancy, prioritize neighborhood fit, layout, and long-term livability. The best choice depends on your timeline, financing profile, and risk tolerance.</p>
        </div>
      </article>
      <% } %>
    </div>
    <p class="berlin-faq__source"><%= t('berlin.faqSource','Sources: Berlin Hyp & CBRE Housing Market Report Berlin 2025.') %> <a href="https://www.berlinhyp.de/en/newsroom/press-information/housing-market-report-berlin-2025-asking-rents-continue-to-rise-rapidly" rel="noopener noreferrer" target="_blank">Berlin Hyp &amp; CBRE Housing Market Report Berlin 2025</a></p>
  </section>
</div>

<script>
document.querySelectorAll('[data-faq-toggle]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var expanded = this.getAttribute('aria-expanded') === 'true';
    var targetId = this.getAttribute('aria-controls');
    var target = targetId ? document.getElementById(targetId) : null;
    this.setAttribute('aria-expanded', !expanded);
    if (target) target.hidden = expanded;
  });
});

document.querySelectorAll('[data-neighborhood-toggle]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var currentExpanded = this.getAttribute('aria-expanded') === 'true';
    var currentPanelId = this.getAttribute('aria-controls');
    var currentPanel = currentPanelId ? document.getElementById(currentPanelId) : null;
    var currentCard = this.closest('[data-neighborhood-card]');

    document.querySelectorAll('[data-neighborhood-toggle]').forEach(function(otherBtn) {
      var expanded = otherBtn.getAttribute('aria-expanded') === 'true';
      if (!expanded) return;
      otherBtn.setAttribute('aria-expanded', 'false');
      var panelId = otherBtn.getAttribute('aria-controls');
      var panel = panelId ? document.getElementById(panelId) : null;
      if (panel) panel.hidden = true;
      var card = otherBtn.closest('[data-neighborhood-card]');
      if (card) card.classList.remove('is-open');
    });

    if (!currentExpanded) {
      this.setAttribute('aria-expanded', 'true');
      if (currentPanel) currentPanel.hidden = false;
      if (currentCard) currentCard.classList.add('is-open');
    } else {
      this.setAttribute('aria-expanded', 'false');
      if (currentPanel) currentPanel.hidden = true;
      if (currentCard) currentCard.classList.remove('is-open');
    }
  });
});

document.querySelectorAll('[data-neighborhood-card]').forEach(function(card) {
  card.addEventListener('click', function(event) {
    if (event.target.closest('[data-neighborhood-toggle]') || event.target.closest('[data-neighborhood-cta]')) return;
    var toggle = card.querySelector('[data-neighborhood-toggle]');
    if (toggle) toggle.click();
  });
});

(function initBerlinBuyerPlaybook() {
  var tabs = Array.prototype.slice.call(document.querySelectorAll('[data-playbook-tab]'));
  var panels = Array.prototype.slice.call(document.querySelectorAll('[data-playbook-panel]'));
  if (!tabs.length || !panels.length) return;

  function activateTab(name) {
    tabs.forEach(function(btn) {
      var active = btn.getAttribute('data-playbook-tab') === name;
      btn.classList.toggle('is-active', active);
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function(panel) {
      var active = panel.getAttribute('data-playbook-panel') === name;
      panel.classList.toggle('is-active', active);
      panel.hidden = !active;
    });
  }

  tabs.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activateTab(btn.getAttribute('data-playbook-tab'));
    });
  });

  var priceInput = document.querySelector('[data-cost-input="price"]');
  var notaryInput = document.querySelector('[data-cost-input="notary"]');
  var brokerInput = document.querySelector('[data-cost-input="broker"]');
  if (priceInput && notaryInput && brokerInput) {
    var priceValueEl = document.getElementById('berlin-cost-price-value');
    var taxValueEl = document.getElementById('berlin-cost-tax-value');
    var notaryValueEl = document.getElementById('berlin-cost-notary-value');
    var brokerValueEl = document.getElementById('berlin-cost-broker-value');
    var totalValueEl = document.getElementById('berlin-cost-total-value');

    function formatEur(value) {
      return 'EUR ' + Number(value || 0).toLocaleString('en-US', { maximumFractionDigits: 0 });
    }

    function recalcCosts() {
      var price = Math.max(Number(priceInput.value) || 0, 0);
      var notaryPct = Math.max(Number(notaryInput.value) || 0, 0);
      var brokerPct = Math.max(Number(brokerInput.value) || 0, 0);
      var transferTax = price * 0.06;
      var notaryAndRegistry = price * (notaryPct / 100);
      var brokerShare = price * (brokerPct / 100);
      var total = price + transferTax + notaryAndRegistry + brokerShare;

      if (priceValueEl) priceValueEl.textContent = formatEur(price);
      if (taxValueEl) taxValueEl.textContent = formatEur(transferTax);
      if (notaryValueEl) notaryValueEl.textContent = formatEur(notaryAndRegistry);
      if (brokerValueEl) brokerValueEl.textContent = formatEur(brokerShare);
      if (totalValueEl) totalValueEl.textContent = formatEur(total);
    }

    [priceInput, notaryInput, brokerInput].forEach(function(input) {
      input.addEventListener('input', recalcCosts);
      input.addEventListener('change', recalcCosts);
    });
    recalcCosts();
  }

  document.querySelectorAll('[data-timeline-toggle]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      var targetId = btn.getAttribute('aria-controls');
      var target = targetId ? document.getElementById(targetId) : null;
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      if (target) target.hidden = expanded;
    });
  });
})();
</script>
<script>
// Header solidify on scroll (same as home)
(function headerShrink() {
  var header = document.querySelector('.site-header.gradient') || document.querySelector('.site-header');
  if (!header) return;
  function update() {
    if (window.scrollY > 40) header.classList.add('shrink');
    else header.classList.remove('shrink');
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function run() {
      update();
      window.addEventListener('scroll', update, { passive: true });
    });
  } else {
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
})();

(function() {
  var locationsEl = document.getElementById('locations-data');
  var neighborhoodCounts = {};
  if (locationsEl && typeof window !== 'undefined') {
    try {
      window.locations = JSON.parse(locationsEl.getAttribute('data-locations') || '{}');
    } catch (e) {}
    try {
      neighborhoodCounts = JSON.parse(locationsEl.getAttribute('data-neighborhood-counts') || '{}');
    } catch (e) { neighborhoodCounts = {}; }
  }
  var countrySelect = document.getElementById('country');
  var citySelect = document.getElementById('city');
  var neighborhoodSelect = document.getElementById('neighborhood');
  if (countrySelect && citySelect && neighborhoodSelect && window.locations) {
    citySelect.disabled = false;
    countrySelect.addEventListener('change', function() {
      var country = this.value;
      citySelect.innerHTML = '<option value="">' + (document.documentElement.lang === 'de' ? 'Stadt' : document.documentElement.lang === 'es' ? 'Ciudad' : 'City') + '</option>';
      neighborhoodSelect.innerHTML = '<option value="">' + (document.documentElement.lang === 'de' ? 'Stadtteil' : document.documentElement.lang === 'es' ? 'Barrio' : 'Neighborhood') + '</option>';
      neighborhoodSelect.disabled = true;
      if (country && window.locations[country]) {
        Object.keys(window.locations[country]).forEach(function(ct) {
          var opt = document.createElement('option');
          opt.value = ct;
          opt.textContent = ct;
          citySelect.appendChild(opt);
        });
        citySelect.disabled = false;
      } else {
        citySelect.disabled = true;
      }
    });
    citySelect.addEventListener('change', function() {
      var country = countrySelect.value;
      var city = this.value;
      neighborhoodSelect.innerHTML = '<option value="">' + (document.documentElement.lang === 'de' ? 'Stadtteil' : document.documentElement.lang === 'es' ? 'Barrio' : 'Neighborhood') + '</option>';
      if (country && city && window.locations[country] && window.locations[country][city]) {
        var neighborhoods = window.locations[country][city];
        if (Array.isArray(neighborhoods) && neighborhoods.length > 0) {
          neighborhoods.forEach(function(n) {
            var count = Number((neighborhoodCounts[country] && neighborhoodCounts[country][city] && neighborhoodCounts[country][city][n]) || 0) || 0;
            var opt = document.createElement('option');
            opt.value = n;
            opt.textContent = n + ' (' + count + ')';
            neighborhoodSelect.appendChild(opt);
          });
          neighborhoodSelect.disabled = false;
        } else {
          neighborhoodSelect.disabled = false;
        }
      } else {
        neighborhoodSelect.disabled = true;
      }
    });
    if (countrySelect.value === 'Germany' && window.locations.Germany) {
      if (citySelect.options.length <= 1) {
        Object.keys(window.locations.Germany).forEach(function(ct) {
          var opt = document.createElement('option');
          opt.value = ct;
          opt.textContent = ct;
          citySelect.appendChild(opt);
        });
      }
      citySelect.value = 'Berlin';
      citySelect.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }
})();
</script>
