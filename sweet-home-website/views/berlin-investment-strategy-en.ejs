  .investor-strategy-explainer__notes p {
    margin: 0;
    color: #3f4f61;
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .investor-strategy-explainer__notes p + p {
    margin-top: 8px;
  }
  .investor-status-badge {
    margin: 10px 0 0;
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    background: #eef2ff;
    color: #1f3a8a;
