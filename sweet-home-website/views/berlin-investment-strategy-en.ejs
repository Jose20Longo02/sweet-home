    font-weight: 600;
  }
  @media (max-width: 992px) {
    .berlin-investor-hero__inner {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 46px 24px 26px;
    }
    .berlin-investor-hero__accent {
      max-width: 360px;
    }
    .berlin-investor-hero__baseline {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 8px 24px 20px;
    }
    .investor-strategy-explainer__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .berlin-investor-hero--luxury { margin-top: 0; }
    .berlin-investor-hero__cta { width: 100%; }
    .berlin-investor-hero__cta .btn,
    .berlin-investor-btn-secondary { width: 100%; text-align: center; }
