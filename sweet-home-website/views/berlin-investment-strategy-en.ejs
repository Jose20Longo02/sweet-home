    border: 1px solid #cfe1d6;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(244, 250, 246, 0.98) 100%);
    border-radius: 12px;
    padding: 14px 15px 13px;
    box-shadow: 0 8px 18px rgba(27, 35, 24, 0.06);
    overflow: hidden;
  }
  .berlin-investor-stat::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, #2ea862 0%, #7cc796 100%);
  }
  .berlin-investor-stat__value {
    margin: 0 0 5px;
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    line-height: 1;
    color: #121826;
    font-weight: 700;
    font-family: 'Playfair Display', Georgia, serif;
    letter-spacing: -0.01em;
  }
  .berlin-investor-stat__label {
    margin: 0;
    color: #4a5565;
    font-size: 0.82rem;
    line-height: 1.45;
  }
  .berlin-investor-hero__baseline {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 34px 22px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
