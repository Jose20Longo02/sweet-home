    margin: 18px 0 0;
    background:
      radial-gradient(circle at 82% 22%, rgba(46, 168, 98, 0.08), transparent 42%),
      linear-gradient(180deg, #fbfefc 0%, #f2f8f4 100%);
    border-top: 1px solid #d6e6db;
    border-bottom: 1px solid #d6e6db;
  }
  .berlin-investor-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 70px 34px 40px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 270px;
    gap: 44px;
    align-items: end;
  }
  .berlin-investor-hero__inner,
  .berlin-investor-hero__inner * {
    text-shadow: none !important;
  }
  .berlin-investor-hero__main { max-width: 780px; }
