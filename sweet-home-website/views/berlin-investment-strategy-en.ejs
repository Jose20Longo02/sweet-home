  .berlin-hero__kicker {
    margin: 0 0 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748b;
    font-size: 0.78rem;
  }
  .berlin-hero__title {
    margin: 0 0 14px;
    color: #16181d;
    line-height: 1.14;
    font-size: clamp(2rem, 3.6vw, 3rem);
    letter-spacing: -0.01em;
  }
  .berlin-hero__description {
    margin: 0;
    color: #3f4856;
    font-size: 1.06rem;
    line-height: 1.65;
    max-width: 760px;
  }
  .berlin-investor-trigger {
    margin: 18px 0 0;
    display: inline-flex;
    align-items: center;
