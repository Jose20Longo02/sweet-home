<% useMainContainer = false %>
<% useHomeHeader = false %>
<link rel="stylesheet" href="/css/home.css" />
<link rel="stylesheet" href="/css/berlin-landing.min.css?v=20260326-3" />
<link rel="stylesheet" href="/css/contact.css?v=<%= assetVersion %>" />
<link rel="stylesheet" href="/css/owners.css?v=<%= assetVersion %>" />
<% if (process.env.RECAPTCHA_SITE_KEY) { %>
  <script src="https://www.google.com/recaptcha/api.js?render=<%= process.env.RECAPTCHA_SITE_KEY %>"></script>
<% } %>

<div class="berlin-landing-page berlin-investor-page">
  <section class="berlin-investor-hero berlin-investor-hero--luxury" aria-labelledby="investor-hero-title">
    <div class="berlin-investor-hero__inner">
      <div class="berlin-investor-hero__main">
        <p class="berlin-hero__kicker">Sweet Home | Private Investor Series</p>
        <h1 id="investor-hero-title" class="berlin-hero__title">The Berlin Property Strategy for Young Professionals Earning EUR 2,700+/month That Almost No One Talks About</h1>
        <p class="berlin-hero__description">If you are young and earning around EUR 2,700+ net per month, this strategy is designed to help you enter the market through tenant-occupied assets with discounted entry potential, day-one rent visibility, and long-term upside.</p>
      </div>
      <aside class="berlin-investor-hero__accent" aria-label="Strategy highlights">
        <div class="berlin-investor-stat">
          <p class="berlin-investor-stat__value">30-40%</p>
          <p class="berlin-investor-stat__label">Potential entry <strong>discount</strong> vs selected vacant comparables</p>
        </div>
        <div class="berlin-investor-stat">
          <p class="berlin-investor-stat__value">Day 1</p>
          <p class="berlin-investor-stat__label"><strong>Income</strong> from day one through tenant-occupied entry</p>
        </div>
        <div class="berlin-investor-stat">
          <p class="berlin-investor-stat__value">~222k</p>
          <p class="berlin-investor-stat__label">Homes <strong>needed</strong> by 2040 in Berlin</p>
        </div>
      </aside>
      <div class="berlin-investor-hero__cta">
        <a href="#lead-cta" class="btn btn-primary">Get personalized advice</a>
        <a href="#selected-berlin-opportunities" class="btn berlin-investor-btn-secondary">Discover selected properties</a>
      </div>
    </div>
  </section>
  <section class="berlin-investor-hero-spacer" aria-hidden="true">
    <div class="berlin-investor-hero-spacer__line"></div>
  </section>

  <section class="berlin-content section investor-strategy-explainer" aria-labelledby="strategy-explainer-heading">
    <div class="berlin-content__inner">
      <div class="investor-strategy-explainer__intro">
        <div class="investor-strategy-explainer__eyebrow">Strategy Framework</div>
        <h2 id="strategy-explainer-heading" class="berlin-content__title">What makes this strategy so attractive?</h2>
        <p class="berlin-content__intro">
          The model combines discounted entry, immediate rent visibility, and long-term asset improvement. It is designed to be financially disciplined while keeping upside potential in view.
        </p>
      </div>

      <div class="investor-strategy-explainer__grid">
        <article class="investor-strategy-explainer__card">
          <span class="investor-strategy-explainer__index">01</span>
          <h3>Income from day one</h3>
          <p>Tenant-occupied entry means rent can already be in place at acquisition, supporting immediate cash-flow visibility.</p>
        </article>

        <article class="investor-strategy-explainer__card">
          <span class="investor-strategy-explainer__index">02</span>
          <h3>Discounted entry + long-term optionality</h3>
          <p>Entry can be materially below vacant comparables (about 30-40% in selected cases), while preserving long-term value and future self-use optionality within legal timelines.</p>
        </article>

        <article class="investor-strategy-explainer__card">
          <span class="investor-strategy-explainer__index">03</span>
          <h3>Energy-efficiency upgrade support</h3>
          <p>Where eligible, subsidy programs can support energy upgrades, improving quality and long-term operating performance.</p>
        </article>
      </div>

      <div class="investor-strategy-explainer__notes">
        <ol class="investor-strategy-explainer__notes-list">
          <li><strong>Low-equity logic:</strong> this model is often structured to optimize equity deployment rather than maximize upfront capital.</li>
          <li><strong>Financing logic:</strong> mortgage capacity is commonly evaluated against income versus actual expenses and debt service affordability.</li>
          <li><strong>Tax logic:</strong> annual interest and depreciation deductions may improve net performance, depending on buyer profile and local tax treatment.</li>
        </ol>
      </div>
      <p class="section-inline-cta">
        <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Get personalized advice on this strategy</a>
      </p>
    </div>
  </section>

  <section class="berlin-content section strategy-mechanics" aria-labelledby="strategy-mechanics-heading">
    <div class="berlin-content__inner">
      <div class="strategy-mechanics__intro">
        <h2 id="strategy-mechanics-heading" class="berlin-content__title">What this strategy actually is, and why it works</h2>
        <p class="berlin-content__intro">
          This strategy combines tenant-occupied entry, immediate rent visibility, and tax/energy-efficiency logic. The advantage is not one single element, but how these elements work together over time.
        </p>
      </div>

      <div class="strategy-mechanics__process" aria-label="Interactive strategy process map">
        <div class="strategy-mechanics__process-line" aria-hidden="true"></div>

        <article class="strategy-mechanics__point strategy-mechanics__point--right is-active" data-mechanics-step="1" tabindex="0">
          <span class="strategy-mechanics__marker"><span></span><small>01</small></span>
          <div class="strategy-mechanics__card">
            <span class="strategy-mechanics__index">01</span>
            <h3>Why a 30-40% discount can happen</h3>
            <p>Tenant-occupied units can trade below comparable vacant units because immediate self-use is limited and buyer demand is narrower. Lower competition can translate into lower entry pricing.</p>
          </div>
        </article>

        <article class="strategy-mechanics__point strategy-mechanics__point--left" data-mechanics-step="2" tabindex="0">
          <span class="strategy-mechanics__marker"><span></span><small>02</small></span>
          <div class="strategy-mechanics__card">
            <span class="strategy-mechanics__index">02</span>
            <h3>Why income can start from day one</h3>
            <p>A tenant is already in place, so rent can already be flowing when you acquire the property. That can provide immediate monthly cash-flow visibility.</p>
          </div>
        </article>

        <article class="strategy-mechanics__point strategy-mechanics__point--right" data-mechanics-step="3" tabindex="0">
          <span class="strategy-mechanics__marker"><span></span><small>03</small></span>
          <div class="strategy-mechanics__card">
            <span class="strategy-mechanics__index">03</span>
            <h3>Where tax benefits come from</h3>
            <p>For many landlord profiles in Germany, interest and depreciation can be deductible. Depending on income and structure, this can improve net after-tax performance.</p>
          </div>
        </article>

        <article class="strategy-mechanics__point strategy-mechanics__point--left" data-mechanics-step="4" tabindex="0">
          <span class="strategy-mechanics__marker"><span></span><small>04</small></span>
          <div class="strategy-mechanics__card">
            <span class="strategy-mechanics__index">04</span>
            <h3>Where energy and financing benefits come from</h3>
            <p>Eligible properties and upgrade paths can support better financing conditions and stronger long-term quality through energy-efficiency programs and lower running risks.</p>
          </div>
        </article>
      </div>

      <p class="strategy-mechanics__disclaimer">
        Important: discount ranges, tax impact, and financing outcomes depend on each property and buyer profile. This page is informational and not legal or tax advice.
      </p>
      <p class="section-inline-cta">
        <a href="#strategy-calculator" class="btn btn-primary section-inline-cta__link">Check if this strategy fits your profile</a>
      </p>
    </div>
  </section>

  <section id="strategy-calculator" class="berlin-content section strategy-calculator" aria-labelledby="strategy-calculator-heading">
    <div class="berlin-content__inner">
      <div class="strategy-calculator__intro">
        <h2 id="strategy-calculator-heading" class="berlin-content__title">Is This Strategy Right for You? Find Out!</h2>
        <p class="berlin-content__intro">
          Estimate whether this strategy matches your profile. The model includes household living-cost logic, fixed expenses, purchase extra costs, equity, and a mortgage payment check.
        </p>
      </div>

      <div class="strategy-calculator__wizard" data-current-step="1">
        <div class="strategy-calculator__progress" role="list" aria-label="Calculator steps">
          <span class="strategy-calculator__progress-item is-active" data-step-indicator="1" role="listitem">1. Income</span>
          <span class="strategy-calculator__progress-item" data-step-indicator="2" role="listitem">2. Household</span>
          <span class="strategy-calculator__progress-item" data-step-indicator="3" role="listitem">3. Property</span>
        </div>

        <div class="strategy-calculator__steps">
          <article class="strategy-calculator__panel strategy-calculator__step is-active" data-step="1">
            <h3>Step 1: Income and fixed monthly costs</h3>
            <div class="strategy-calculator__fields">
              <div class="strategy-calculator__field">
                <label for="calcSalary1">Net monthly salary (EUR)</label>
                <input id="calcSalary1" type="number" min="0" step="50" value="2700" inputmode="decimal">
              </div>
              <div class="strategy-calculator__field">
                <label for="calcLoans">Current monthly loan payments (EUR)</label>
                <input id="calcLoans" type="number" min="0" step="50" value="400" inputmode="decimal">
              </div>
              <div class="strategy-calculator__field">
                <label for="calcInsurance">Private insurance (monthly, EUR)</label>
                <input id="calcInsurance" type="number" min="0" step="50" value="200" inputmode="decimal">
              </div>
            </div>
          </article>

          <article class="strategy-calculator__panel strategy-calculator__step" data-step="2" hidden>
            <h3>Step 2: Household expenses profile</h3>
            <p class="strategy-calculator__step-hint">Living-cost model: 1 adult = EUR 1,200 | 2 adults = EUR 1,600 | each child = +EUR 200.</p>
            <div class="strategy-calculator__fields">
              <div class="strategy-calculator__field">
                <label for="calcAdults">Adults in household</label>
                <select id="calcAdults">
                  <option value="1">1 adult</option>
                  <option value="2" selected>2 adults</option>
                </select>
              </div>
              <div class="strategy-calculator__field">
                <label for="calcChildren">Children in household</label>
                <input id="calcChildren" type="number" min="0" step="1" value="1" inputmode="numeric">
              </div>
            </div>
          </article>

          <article class="strategy-calculator__panel strategy-calculator__step" data-step="3" hidden>
            <h3>Step 3: Property and financing assumptions</h3>
            <div class="strategy-calculator__fields">
              <div class="strategy-calculator__field">
                <label for="calcPropertyPrice">Property price (EUR)</label>
                <input id="calcPropertyPrice" type="number" min="0" step="1000" value="300000" inputmode="decimal">
              </div>
              <div class="strategy-calculator__field">
                <label for="calcEquityPct">Upfront payment (% of property value, minimum 12%)</label>
                <input id="calcEquityPct" type="number" min="12" max="100" step="1" value="12" inputmode="decimal">
              </div>
              <div class="strategy-calculator__field">
                <label for="calcDebtServiceRate">Estimated annual debt-service rate (%)</label>
                <input id="calcDebtServiceRate" type="number" min="0" max="20" step="0.1" value="6" inputmode="decimal">
              </div>
            </div>
          </article>
        </div>

        <div class="strategy-calculator__actions">
          <button type="button" id="calcPrevBtn" class="strategy-calculator__btn strategy-calculator__btn--ghost">Back</button>
          <button type="button" id="calcNextBtn" class="strategy-calculator__btn strategy-calculator__btn--primary">Next</button>
          <button type="button" id="calcRunBtn" class="strategy-calculator__btn strategy-calculator__btn--primary" hidden>Calculate suitability</button>
        </div>
      </div>

      <div id="strategyCalculatorResults" class="strategy-calculator__results-wrap" hidden>
        <div class="strategy-calculator__results" aria-live="polite">
        <div class="strategy-calculator__result">
          <span class="strategy-calculator__result-label">Total monthly income</span>
          <strong id="calcTotalIncome">EUR 0</strong>
        </div>
        <div class="strategy-calculator__result">
          <span class="strategy-calculator__result-label">Household living expenses</span>
          <strong id="calcLivingExpenses">EUR 0</strong>
        </div>
        <div class="strategy-calculator__result">
          <span class="strategy-calculator__result-label">Total monthly expenses</span>
          <strong id="calcTotalExpenses">EUR 0</strong>
        </div>
        <div class="strategy-calculator__result">
          <span class="strategy-calculator__result-label">Final balance after expenses</span>
          <strong id="calcFinalBalance">EUR 0</strong>
        </div>
        <div class="strategy-calculator__result">
          <span class="strategy-calculator__result-label">Estimated monthly payment (Geschätzt)</span>
          <strong id="calcEstimatedPayment">EUR 0</strong>
        </div>
        <div class="strategy-calculator__result">
          <span class="strategy-calculator__result-label">Required net salary</span>
          <strong id="calcRequiredSalary">EUR 0</strong>
        </div>
        <div class="strategy-calculator__result strategy-calculator__result--status">
          <span class="strategy-calculator__result-label">Suitability check</span>
          <strong id="calcQualificationStatus">Not qualified yet</strong>
          <span id="calcStatusPill" class="strategy-calculator__status-pill">Waiting for calculation</span>
          <div class="strategy-calculator__status-metrics">
            <div class="strategy-calculator__status-metric">
              <span>Capacity gap</span>
              <strong id="calcCapacityGap">EUR 0</strong>
            </div>
            <div class="strategy-calculator__status-metric">
              <span>Coverage ratio</span>
              <strong id="calcCoverageRatio">0%</strong>
            </div>
          </div>
          <ul id="calcImprovementList" class="strategy-calculator__improvement-list" hidden></ul>
        </div>
        </div>

        <div class="strategy-calculator__derived">
          <div class="strategy-calculator__derived-item">
            <span class="strategy-calculator__result-label">Purchase extra costs (12% of price)</span>
            <strong id="calcExtraCosts">EUR 0</strong>
          </div>
          <div class="strategy-calculator__derived-item">
            <span class="strategy-calculator__result-label">Total equity required</span>
            <strong id="calcTotalEquity">EUR 0</strong>
          </div>
          <div class="strategy-calculator__derived-item">
            <span class="strategy-calculator__result-label">Mortgage amount</span>
            <strong id="calcMortgage">EUR 0</strong>
          </div>
        </div>
      </div>

      <p id="calcQualificationNote" class="strategy-calculator__note">
        Complete the 3 steps and click <strong>Calculate suitability</strong> to see your personalized result.
      </p>
      <p class="section-inline-cta">
        <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Discuss your calculator result with an advisor</a>
      </p>
    </div>
  </section>

  <section id="selected-berlin-opportunities" class="section featured berlin-featured" aria-labelledby="campaign-properties-heading">
    <h2 id="campaign-properties-heading" class="berlin-featured__title">Selected Berlin opportunities</h2>
    <p class="berlin-featured__subtitle">We are currently focusing campaign traffic on selected tenant-occupied opportunities, including two priority project-style entries where lower entry pricing and long-term fundamentals can align.</p>
    <div class="berlin-featured__grid" id="investorRecommended">
      <% (recommendedProperties || []).forEach((property, idx) => { %>
        <%
          const photoUrl = (property.photos && property.photos[0]) ? property.photos[0] : '/img/property-placeholder.jpg';
          const size = property.size ? `${property.size} m²` : null;
          const beds = (typeof property.rooms !== 'undefined' && property.rooms !== null) ? property.rooms : null;
          const baths = (typeof property.bathrooms !== 'undefined' && property.bathrooms !== null) ? property.bathrooms : null;
          const priceText = property.price && Number(property.price) > 0 ? 'EUR ' + Number(property.price).toLocaleString('en-US') : '';
          const statusLabel = property.occupancy_type || property.rental_status || null;
          const prioritizeImage = idx < 3;
        %>
        <article class="property-card">
          <a href="/en/properties/<%= property.slug %>" class="property-card-link">
            <div class="img-wrap" <%= priceText ? `data-price="${priceText}"` : '' %>>
              <img
                src="<%= photoUrl %>"
                alt="<%= property.title %>"
                loading="<%= prioritizeImage ? 'eager' : 'lazy' %>"
                fetchpriority="<%= prioritizeImage ? 'high' : 'low' %>"
                decoding="async"
                onerror="this.src='/img/property-placeholder.jpg'">
            </div>
            <div class="meta">
              <div class="title"><%= property.title %></div>
              <% if (priceText) { %><div class="price"><%= priceText %></div><% } %>
              <div class="location">
                <span class="icon icon-16 icon-inline icon-mask icon-location" style="color: currentColor;"></span>
                <%= property.neighborhood || property.city %>, <%= property.country %>
              </div>
              <div class="features-row">
                <% if (size) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-size"></span>
                    <span><%= size %></span>
                  </div>
                <% } %>
                <% if (beds !== null) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-bed"></span>
                    <span><%= beds %> bed<%= Number(beds) === 1 ? '' : 's' %></span>
                  </div>
                <% } %>
                <% if (baths !== null) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-bath"></span>
                    <span><%= baths %> bath<%= Number(baths) === 1 ? '' : 's' %></span>
                  </div>
                <% } %>
              </div>
              <% if (statusLabel) { %>
                <p class="investor-status-badge"><%= statusLabel %></p>
              <% } %>
              <span class="learn-more">View details →</span>
            </div>
          </a>
        </article>
      <% }); %>
    </div>
    <% if (!recommendedProperties || recommendedProperties.length === 0) { %>
      <p class="section-empty">No properties found right now. <a href="/en/properties?country=Germany&city=Berlin">See all Berlin listings</a>.</p>
    <% } %>
    <p class="section-inline-cta">
      <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Get personalized advice on selected opportunities</a>
    </p>
  </section>

  <section class="berlin-content section" aria-labelledby="faq-heading">
    <div class="berlin-content__inner">
      <h2 id="faq-heading" class="berlin-content__title">Investor FAQ</h2>
      <div class="berlin-content__grid">
        <article class="berlin-content__card">
          <h3>Is this page legal advice?</h3>
          <p>No. This content is informational only and does not replace legal, tax, or investment advice.</p>
        </article>
        <article class="berlin-content__card">
          <h3>Are returns guaranteed?</h3>
          <p>No. Performance depends on asset quality, financing terms, tenant profile, and market conditions.</p>
        </article>
        <article class="berlin-content__card">
          <h3>Can non-residents buy in Berlin?</h3>
          <p>In many cases yes, subject to individual legal and financing checks. We coordinate the process with local partners.</p>
        </article>
        <article class="berlin-content__card">
          <h3>Can I get options that match my budget?</h3>
          <p>Yes. We prepare a shortlist based on your criteria, including district, condition, occupancy, and entry level.</p>
        </article>
      </div>
      <p class="berlin-neighborhoods__source">
        Sources referenced in this strategy: Berlin Senate Department for Urban Development, IBB Housing Market Report, and the German Civil Code (BGB) framework.
      </p>
      <p class="berlin-neighborhoods__source">
        Important note on the "45% cheaper" trigger: it is a campaign benchmark based on selected occupied-vs-vacant comparisons and is not a guaranteed discount for every unit.
      </p>
      <p class="section-inline-cta">
        <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Still have questions? Speak with an advisor</a>
      </p>
    </div>
  </section>

  <section id="lead-cta" class="owners-lead section">
    <h2 id="investor-form-heading">Request strategy details</h2>
    <div class="lead-grid">
      <form
        id="berlinInvestorStrategyForm"
        class="lead-form lead-form-centered"
        action="/api/leads/berlin-investor-strategy"
        method="post"
        novalidate
        <% if (process.env.RECAPTCHA_SITE_KEY) { %> data-recaptcha-site-key="<%= process.env.RECAPTCHA_SITE_KEY %>" <% } %>
      >
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (process.env.RECAPTCHA_SITE_KEY) { %>
          <input type="hidden" name="recaptchaToken" id="recaptchaTokenInvestorStrategy" />
        <% } %>
        <input type="text" name="hp_field" tabindex="-1" autocomplete="off" style="position:absolute; left:-10000px; top:auto; width:1px; height:1px; overflow:hidden;" aria-hidden="true">

        <div class="form-group">
          <label for="fullName">Full name*</label>
          <input id="fullName" name="name" type="text" required aria-required="true" placeholder="Full name*">
        </div>
        <div class="row-2">
          <div class="form-group">
            <label for="countryCode">Country code*</label>
            <input id="countryCode" name="countryCode" type="text" required aria-required="true" placeholder="+49">
          </div>
          <div class="form-group">
            <label for="phone">Phone number*</label>
            <input id="phone" name="phone" type="tel" required aria-required="true" placeholder="Phone number*" inputmode="tel">
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email*</label>
          <input id="email" name="email" type="email" required aria-required="true" placeholder="Email*">
        </div>
        <div class="form-group">
          <label for="language">Preferred language</label>
          <select id="language" name="language">
            <option value="">Select language</option>
            <% (supportedLanguages || ['en','es','de']).forEach(function(code){ %>
              <option value="<%= code %>" <%= (lang===code ? 'selected' : '') %>><%= (languageLabels && languageLabels[code]) || code.toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Message (optional)</label>
          <input id="message" name="message" type="text" placeholder="Tell us your investment goals, budget range, or timeline.">
        </div>

        <input type="hidden" name="utm_source" />
        <input type="hidden" name="utm_medium" />
        <input type="hidden" name="utm_campaign" />
        <input type="hidden" name="utm_term" />
        <input type="hidden" name="utm_content" />
        <input type="hidden" name="referrer" />
        <input type="hidden" name="page_path" />

        <button type="submit" class="btn-submit">Contact us</button>
        <p class="form-status" role="status" aria-live="polite" style="display:none"></p>
      </form>
    </div>
  </section>
</div>

<style>
  .berlin-investor-page .section {
    margin-top: 54px;
  }
  .berlin-investor-hero--luxury {
    position: relative;
    margin: 18px 0 0;
    background:
      radial-gradient(circle at 82% 22%, rgba(46, 168, 98, 0.08), transparent 42%),
      linear-gradient(180deg, #fbfefc 0%, #f2f8f4 100%);
    border-top: 1px solid #d6e6db;
    border-bottom: 1px solid #d6e6db;
  }
  .berlin-investor-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 70px 34px 40px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 270px;
    grid-template-areas:
      "main accent"
      "cta accent";
    gap: 44px;
    align-items: center;
  }
  .berlin-investor-hero__inner,
  .berlin-investor-hero__inner * {
    text-shadow: none !important;
  }
  .berlin-investor-hero__main {
    grid-area: main;
    max-width: 780px;
    align-self: center;
  }
  .berlin-investor-hero__accent {
    grid-area: accent;
    display: grid;
    gap: 12px;
    margin-bottom: 0;
    align-self: center;
  }
  .berlin-investor-stat {
    position: relative;
    border: 1px solid #cfe1d6;
