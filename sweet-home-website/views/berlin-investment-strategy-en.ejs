  }
  .berlin-investor-btn-secondary:hover { background: #f8faf8; color: #1f2a1f; }
  .investor-strategy-explainer {
    padding-top: 46px;
    padding-bottom: 16px;
  }
  .investor-strategy-explainer__intro {
    position: relative;
    margin-bottom: 22px;
    padding: 0 0 18px;
    border-bottom: 1px solid #d7e6dc;
  }
  .investor-strategy-explainer__eyebrow {
    display: inline-block;
    margin-bottom: 10px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid #cae0d4;
    background: #f6fbf8;
    color: #2d6a46;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .investor-strategy-explainer .berlin-content__title {
    margin-bottom: 10px;
