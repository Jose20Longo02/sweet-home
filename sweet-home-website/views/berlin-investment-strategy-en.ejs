<% useMainContainer = false %>
<% useHomeHeader = false %>
<link rel="stylesheet" href="/css/home.css" />
<link rel="stylesheet" href="/css/berlin-landing.min.css?v=20260326-3" />
<link rel="stylesheet" href="/css/contact.css?v=<%= assetVersion %>" />
<link rel="stylesheet" href="/css/owners.css?v=<%= assetVersion %>" />
<% if (process.env.RECAPTCHA_SITE_KEY) { %>
  <script src="https://www.google.com/recaptcha/api.js?render=<%= process.env.RECAPTCHA_SITE_KEY %>"></script>
<% } %>

<div class="berlin-landing-page berlin-investor-page">
  <section class="berlin-investor-hero berlin-investor-hero--luxury" aria-labelledby="investor-hero-title">
    <div class="berlin-investor-hero__inner">
      <div class="berlin-investor-hero__main">
        <p class="berlin-hero__kicker">Sweet Home | Private Investor Series</p>
        <h1 id="investor-hero-title" class="berlin-hero__title">Berlin Tenant-Occupied Entry Strategy</h1>
        <p class="berlin-hero__description">A premium long-hold strategy to enter Berlin through tenant-occupied assets with immediate rental cash-flow potential and a disciplined value-focused approach.</p>
        <div class="berlin-investor-hero__cta">
          <a href="#lead-cta" class="btn btn-primary">Contact us</a>
          <a href="#selected-berlin-opportunities" class="btn berlin-investor-btn-secondary">Discover selected properties</a>
        </div>
      </div>
      <aside class="berlin-investor-hero__accent" aria-label="Strategy highlights">
        <div class="berlin-investor-stat">
          <p class="berlin-investor-stat__value">30-40%</p>
          <p class="berlin-investor-stat__label">Potential entry discount vs selected vacant comparables</p>
        </div>
        <div class="berlin-investor-stat">
          <p class="berlin-investor-stat__value">Day 1</p>
          <p class="berlin-investor-stat__label">Income from day one through tenant-occupied entry</p>
        </div>
        <div class="berlin-investor-stat">
          <p class="berlin-investor-stat__value">~222k</p>
          <p class="berlin-investor-stat__label">Homes needed by 2040 in Berlin</p>
        </div>
      </aside>
    </div>
  </section>
  <section class="berlin-investor-hero-spacer" aria-hidden="true">
    <div class="berlin-investor-hero-spacer__line"></div>
  </section>

  <section class="berlin-content section investor-strategy-explainer" aria-labelledby="strategy-explainer-heading">
    <div class="berlin-content__inner">
      <div class="investor-strategy-explainer__intro">
        <div class="investor-strategy-explainer__eyebrow">Strategy Framework</div>
        <h2 id="strategy-explainer-heading" class="berlin-content__title">What makes this strategy so attractive?</h2>
        <p class="berlin-content__intro">
          The model combines discounted entry, immediate rent visibility, and long-term asset improvement. It is designed to be financially disciplined while keeping upside potential in view.
        </p>
      </div>

      <div class="investor-strategy-explainer__grid">
        <article class="investor-strategy-explainer__card">
          <span class="investor-strategy-explainer__index">01</span>
          <h3>Income from day one</h3>
          <p>Tenant-occupied entry means rent can already be in place at acquisition, supporting immediate cash-flow visibility.</p>
        </article>

        <article class="investor-strategy-explainer__card">
          <span class="investor-strategy-explainer__index">02</span>
          <h3>Discounted entry + long-term optionality</h3>
          <p>Entry can be materially below vacant comparables (about 30-40% in selected cases), while preserving long-term value and future self-use optionality within legal timelines.</p>
        </article>

        <article class="investor-strategy-explainer__card">
          <span class="investor-strategy-explainer__index">03</span>
          <h3>Energy-efficiency upgrade support</h3>
          <p>Where eligible, subsidy programs can support energy upgrades, improving quality and long-term operating performance.</p>
        </article>
      </div>

      <div class="investor-strategy-explainer__notes">
        <ol class="investor-strategy-explainer__notes-list">
          <li><strong>Low-equity logic:</strong> this model is often structured to optimize equity deployment rather than maximize upfront capital.</li>
          <li><strong>Financing logic:</strong> mortgage capacity is commonly evaluated against income versus actual expenses and debt service affordability.</li>
          <li><strong>Tax logic:</strong> annual interest and depreciation deductions may improve net performance, depending on buyer profile and local tax treatment.</li>
        </ol>
      </div>
      <p class="section-inline-cta">
        <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Get personalized advice on this strategy</a>
      </p>
    </div>
  </section>

  <section class="berlin-content section investor-fit" aria-labelledby="strategy-fit-heading">
    <div class="berlin-content__inner">
      <div class="investor-fit__intro">
        <h2 id="strategy-fit-heading" class="berlin-content__title">Who this strategy is for</h2>
        <p class="berlin-content__intro">This model is ideal for buyers who prioritize discounted entry, stable income, tax efficiency, and long-term positioning over short-term speculation.</p>
      </div>
      <div class="investor-fit__list">
        <article class="investor-fit__item">
          <div class="investor-fit__item-head">
            <span class="investor-fit__tag">01</span>
            <h3>Long-term income investors</h3>
          </div>
          <p>Best suited for buyers focused on resilient 5-10+ year positioning, stable rent profile, and capital preservation.</p>
        </article>
        <article class="investor-fit__item">
          <div class="investor-fit__item-head">
            <span class="investor-fit__tag">02</span>
            <h3>Young professionals with stable income</h3>
          </div>
          <p>Relevant for buyers who can afford to wait up to 10 years for self-use rights while benefiting from a lower entry price and potential tax advantages.</p>
        </article>
        <article class="investor-fit__item">
          <div class="investor-fit__item-head">
            <span class="investor-fit__tag">03</span>
            <h3>Value-focused buyers</h3>
          </div>
          <p>Designed for buyers targeting the 30-40% occupied-vs-vacant entry discount in selected opportunities.</p>
        </article>
        <article class="investor-fit__item">
          <div class="investor-fit__item-head">
            <span class="investor-fit__tag">04</span>
            <h3>Modernization-minded owners</h3>
          </div>
          <p>Ideal for those who want to combine the strategy with energy-efficiency upgrades and available subsidy programs where eligible.</p>
        </article>
      </div>
      <p class="section-inline-cta">
        <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Find out if this strategy fits your profile</a>
      </p>
    </div>
  </section>

  <section id="selected-berlin-opportunities" class="section featured berlin-featured" aria-labelledby="campaign-properties-heading">
    <h2 id="campaign-properties-heading" class="berlin-featured__title">Selected Berlin opportunities</h2>
    <div class="berlin-featured__grid" id="investorRecommended">
      <% (recommendedProperties || []).forEach((property, idx) => { %>
        <%
          const photoUrl = (property.photos && property.photos[0]) ? property.photos[0] : '/img/property-placeholder.jpg';
          const size = property.size ? `${property.size} m²` : null;
          const beds = (typeof property.rooms !== 'undefined' && property.rooms !== null) ? property.rooms : null;
          const baths = (typeof property.bathrooms !== 'undefined' && property.bathrooms !== null) ? property.bathrooms : null;
          const priceText = property.price && Number(property.price) > 0 ? 'EUR ' + Number(property.price).toLocaleString('en-US') : '';
          const statusLabel = property.occupancy_type || property.rental_status || null;
          const prioritizeImage = idx < 3;
        %>
        <article class="property-card">
          <a href="/en/properties/<%= property.slug %>" class="property-card-link">
            <div class="img-wrap" <%= priceText ? `data-price="${priceText}"` : '' %>>
              <img
                src="<%= photoUrl %>"
                alt="<%= property.title %>"
                loading="<%= prioritizeImage ? 'eager' : 'lazy' %>"
                fetchpriority="<%= prioritizeImage ? 'high' : 'low' %>"
                decoding="async"
                onerror="this.src='/img/property-placeholder.jpg'">
            </div>
            <div class="meta">
              <div class="title"><%= property.title %></div>
              <% if (priceText) { %><div class="price"><%= priceText %></div><% } %>
              <div class="location">
                <span class="icon icon-16 icon-inline icon-mask icon-location" style="color: currentColor;"></span>
                <%= property.neighborhood || property.city %>, <%= property.country %>
              </div>
              <div class="features-row">
                <% if (size) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-size"></span>
                    <span><%= size %></span>
                  </div>
                <% } %>
                <% if (beds !== null) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-bed"></span>
                    <span><%= beds %> bed<%= Number(beds) === 1 ? '' : 's' %></span>
                  </div>
                <% } %>
                <% if (baths !== null) { %>
                  <div class="feature">
                    <span class="icon icon-16 icon-inline icon-mask icon-bath"></span>
                    <span><%= baths %> bath<%= Number(baths) === 1 ? '' : 's' %></span>
                  </div>
                <% } %>
              </div>
              <% if (statusLabel) { %>
                <p class="investor-status-badge"><%= statusLabel %></p>
              <% } %>
              <span class="learn-more">View details →</span>
            </div>
          </a>
        </article>
      <% }); %>
    </div>
    <% if (!recommendedProperties || recommendedProperties.length === 0) { %>
      <p class="section-empty">No properties found right now. <a href="/en/properties?country=Germany&city=Berlin">See all Berlin listings</a>.</p>
    <% } %>
    <p class="section-inline-cta">
      <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Get personalized advice on selected opportunities</a>
    </p>
  </section>

  <section class="berlin-content section" aria-labelledby="faq-heading">
    <div class="berlin-content__inner">
      <h2 id="faq-heading" class="berlin-content__title">Investor FAQ</h2>
      <div class="berlin-content__grid">
        <article class="berlin-content__card">
          <h3>Is this page legal advice?</h3>
          <p>No. This content is informational only and does not replace legal, tax, or investment advice.</p>
        </article>
        <article class="berlin-content__card">
          <h3>Are returns guaranteed?</h3>
          <p>No. Performance depends on asset quality, financing terms, tenant profile, and market conditions.</p>
        </article>
        <article class="berlin-content__card">
          <h3>Can non-residents buy in Berlin?</h3>
          <p>In many cases yes, subject to individual legal and financing checks. We coordinate the process with local partners.</p>
        </article>
        <article class="berlin-content__card">
          <h3>Can I get options that match my budget?</h3>
          <p>Yes. We prepare a shortlist based on your criteria, including district, condition, occupancy, and entry level.</p>
        </article>
      </div>
      <p class="berlin-neighborhoods__source">
        Sources referenced in this strategy: Berlin Senate Department for Urban Development, IBB Housing Market Report, and the German Civil Code (BGB) framework.
      </p>
      <p class="berlin-neighborhoods__source">
        Important note on the "45% cheaper" trigger: it is a campaign benchmark based on selected occupied-vs-vacant comparisons and is not a guaranteed discount for every unit.
      </p>
      <p class="section-inline-cta">
        <a href="#lead-cta" class="btn btn-primary section-inline-cta__link">Still have questions? Speak with an advisor</a>
      </p>
    </div>
  </section>

  <section id="lead-cta" class="owners-lead section">
    <h2 id="investor-form-heading">Request strategy details</h2>
    <div class="lead-grid">
      <form
        id="berlinInvestorStrategyForm"
        class="lead-form lead-form-centered"
        action="/api/leads/berlin-investor-strategy"
        method="post"
        novalidate
        <% if (process.env.RECAPTCHA_SITE_KEY) { %> data-recaptcha-site-key="<%= process.env.RECAPTCHA_SITE_KEY %>" <% } %>
      >
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (process.env.RECAPTCHA_SITE_KEY) { %>
          <input type="hidden" name="recaptchaToken" id="recaptchaTokenInvestorStrategy" />
        <% } %>
        <input type="text" name="hp_field" tabindex="-1" autocomplete="off" style="position:absolute; left:-10000px; top:auto; width:1px; height:1px; overflow:hidden;" aria-hidden="true">

        <div class="form-group">
          <label for="fullName">Full name*</label>
          <input id="fullName" name="name" type="text" required aria-required="true" placeholder="Full name*">
        </div>
        <div class="row-2">
          <div class="form-group">
            <label for="countryCode">Country code*</label>
            <input id="countryCode" name="countryCode" type="text" required aria-required="true" placeholder="+49">
          </div>
          <div class="form-group">
            <label for="phone">Phone number*</label>
            <input id="phone" name="phone" type="tel" required aria-required="true" placeholder="Phone number*" inputmode="tel">
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email*</label>
          <input id="email" name="email" type="email" required aria-required="true" placeholder="Email*">
        </div>
        <div class="form-group">
          <label for="language">Preferred language</label>
          <select id="language" name="language">
            <option value="">Select language</option>
            <% (supportedLanguages || ['en','es','de']).forEach(function(code){ %>
              <option value="<%= code %>" <%= (lang===code ? 'selected' : '') %>><%= (languageLabels && languageLabels[code]) || code.toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Message (optional)</label>
          <input id="message" name="message" type="text" placeholder="Tell us your investment goals, budget range, or timeline.">
        </div>

        <input type="hidden" name="utm_source" />
        <input type="hidden" name="utm_medium" />
        <input type="hidden" name="utm_campaign" />
        <input type="hidden" name="utm_term" />
        <input type="hidden" name="utm_content" />
        <input type="hidden" name="referrer" />
        <input type="hidden" name="page_path" />

        <button type="submit" class="btn-submit">Contact us</button>
        <p class="form-status" role="status" aria-live="polite" style="display:none"></p>
      </form>
    </div>
    <p class="section-inline-cta section-inline-cta--light">
      <a href="#selected-berlin-opportunities" class="btn btn-primary section-inline-cta__link">Learn more about the strategy through available properties</a>
    </p>
  </section>
</div>

