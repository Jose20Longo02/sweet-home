  .investor-strategy-explainer__card {
    position: relative;
    border: 1px solid #cfe3d7;
    border-radius: 14px;
    background: linear-gradient(180deg, #ffffff 0%, #f4faf7 100%);
    padding: 18px 18px 16px;
    box-shadow: 0 10px 24px rgba(19, 42, 28, 0.05);
