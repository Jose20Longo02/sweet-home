<% if (typeof title === 'undefined' || !title) { title = post.title; } headPartial = '../partials/seo/blog-detail-head'; %>
<link rel="stylesheet" href="/css/blog.css" />
<style>
  .blog-detail .content .internal-landing-link {
    color: #1f7a45;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }
  .blog-detail .content .internal-landing-link--button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: 999px;
    padding: 8px 14px;
    margin: 6px 4px 6px 0;
    background: #1f7a45;
    color: #ffffff;
    border: 1px solid #1f7a45;
    font-weight: 700;
    line-height: 1.2;
  }
  .blog-detail .content .internal-landing-link--button:hover,
  .blog-detail .content .internal-landing-link--button:focus {
    color: #ffffff;
    background: #18673b;
    border-color: #18673b;
  }
  .blog-detail .blog-related-landings {
    margin-top: 18px;
    border: 1px solid #d7e7dc;
    background: linear-gradient(180deg, #ffffff 0%, #f6fbf8 100%);
    border-radius: 12px;
    padding: 16px;
  }
  .blog-detail .blog-related-landings h2 {
    margin: 0 0 8px;
    font-size: 1.2rem;
    color: #152233;
  }
  .blog-detail .blog-related-landings__intro {
    margin: 0 0 10px;
    color: #4b5b6f;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .blog-detail .blog-related-landings__list {
    margin: 0;
    padding-left: 1.15rem;
    display: grid;
    gap: 6px;
  }
  .blog-detail .blog-related-landings__list a {
    color: #1f7a45;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }
  .blog-detail .blog-article header .post-topics {
    margin-bottom: 14px;
  }
  .blog-detail .blog-article header .cover {
    display: block;
    margin-top: 12px;
  }
  .blog-detail .blog-author-badge {
    display: flex !important;
    align-items: center !important;
    gap: 16px !important;
    margin: 16px 0 20px !important;
    padding: 16px 18px !important;
    border: 1px solid #d7e7dc !important;
    border-radius: 14px !important;
    background: linear-gradient(180deg, #ffffff 0%, #f6fbf8 100%) !important;
    box-shadow: 0 4px 18px rgba(21, 34, 51, 0.06) !important;
    max-width: 100% !important;
  }
  .blog-detail .blog-author-badge__avatar {
    flex: 0 0 72px !important;
    width: 72px !important;
    height: 72px !important;
    border-radius: 50% !important;
    overflow: hidden !important;
    border: 2px solid #d7e7dc !important;
    box-shadow: 0 2px 8px rgba(21, 34, 51, 0.08) !important;
  }
  .blog-detail .blog-author-badge__avatar img {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    border-radius: 50% !important;
  }
  .blog-detail .blog-author-badge__body {
    min-width: 0 !important;
    flex: 1 1 auto !important;
  }
  .blog-detail .blog-author-badge__identity {
    display: flex !important;
    flex-wrap: wrap !important;
    align-items: baseline !important;
    gap: 6px !important;
    margin: 0 0 2px !important;
  }
  .blog-detail .blog-author-badge__label {
    margin: 0 !important;
    font-size: 0.78rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.04em !important;
    text-transform: uppercase !important;
    color: #1f7a45 !important;
    line-height: 1.2 !important;
  }
  .blog-detail .blog-author-badge__name {
    margin: 0 !important;
    font-size: 1.08rem !important;
    font-weight: 700 !important;
    color: #152233 !important;
    line-height: 1.25 !important;
  }
  .blog-detail .blog-author-badge__position {
    margin: 0 0 8px !important;
    font-size: 0.92rem !important;
    color: #4b5b6f !important;
    line-height: 1.35 !important;
  }
  .blog-detail .blog-author-badge__contacts {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 8px !important;
  }
  .blog-detail .blog-author-badge__contact {
    display: inline-flex !important;
    align-items: center !important;
    padding: 5px 10px !important;
    border: 1px solid #d7e7dc !important;
    border-radius: 999px !important;
    background: #ffffff !important;
    font-size: 0.84rem !important;
    color: #334155 !important;
    text-decoration: none !important;
    line-height: 1.2 !important;
    word-break: break-word !important;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease !important;
  }
  .blog-detail .blog-author-badge__contact:hover,
  .blog-detail .blog-author-badge__contact:focus {
    color: #1f7a45 !important;
    border-color: #1f7a45 !important;
    background: #f6fbf8 !important;
  }
  @media (max-width: 640px) {
    .blog-detail .blog-author-badge {
      align-items: flex-start !important;
      padding: 14px !important;
    }
    .blog-detail .blog-author-badge__avatar {
      flex-basis: 64px !important;
      width: 64px !important;
      height: 64px !important;
    }
    .blog-detail .blog-author-badge__contacts {
      flex-direction: column !important;
      align-items: flex-start !important;
    }
  }
</style>
<article class="container main blog-detail">
  <div class="blog-detail-grid">
    <aside class="blog-recommended">
      <h3><%= t((postTopicIds && postTopicIds.length) ? 'blog.detail.related' : 'blog.detail.recent', (postTopicIds && postTopicIds.length) ? 'Related articles' : 'Recent articles') %></h3>
      <% if ((recommendedPosts || []).length === 0) { %>
        <p class="empty"><%= t('blog.detail.noRecent','No recent posts.') %></p>
      <% } else { %>
        <ul class="rec-list">
          <% recommendedPosts.forEach(r => { %>
            <li>
              <a class="rec-item" href="<%= (typeof localePath === 'function') ? localePath('/blog/' + r.slug) : '/blog/' + r.slug %>">
                <% if (r.cover_image) { %>
                  <img src="<%= r.cover_image %>" alt="<%= r.title %>" />
                <% } %>
                <div class="rec-info">
                  <span class="rec-title"><%= r.title %></span>
                  <% if (r.author_name) { %>
                    <span class="rec-meta"><%= t('blog.publishedBy','Published by') %> <%= r.author_name %></span>
                  <% } %>
                  <span class="rec-cta"><%= t('blog.read','Read article') %> →</span>
                </div>
              </a>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </aside>
    <div class="blog-article">
      <header>
        <h1><%= post.title %></h1>
        <% 
          const lastUpdatedRaw = post.updated_at || post.published_at || post.created_at;
          const currentLang = (typeof lang !== 'undefined' && lang) ? lang : 'en';
          const localeMap = { de: 'de-DE', es: 'es-ES', en: 'en-US' };
        %>
        <% if (lastUpdatedRaw) { %>
          <p class="meta">
            <%= t('blog.lastUpdated', 'Last updated') %>:
            <%= new Date(lastUpdatedRaw).toLocaleDateString(localeMap[currentLang] || 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
          </p>
        <% } %>
        <% if (post.author_name) { %>
          <% 
            const authorPicRaw = post.author_profile_picture || '';
            const authorPic = authorPicRaw
              ? (/^https?:\/\//.test(authorPicRaw)
                ? authorPicRaw
                : (authorPicRaw.startsWith('/') ? authorPicRaw : '/' + authorPicRaw))
              : '/img/default-avatar.png';
            const authorPhoneHref = post.author_phone
              ? String(post.author_phone).replace(/[^\d+]/g, '')
              : '';
          %>
          <aside class="blog-author-badge" aria-label="<%= t('blog.authorBadgeLabel', 'Article author') %>">
            <div class="blog-author-badge__avatar">
              <img
                src="<%= authorPic %>"
                alt="<%= post.author_name %>"
                width="72"
                height="72"
                loading="lazy"
                onerror="this.onerror=null;this.src='/img/default-avatar.png';"
              />
            </div>
            <div class="blog-author-badge__body">
              <div class="blog-author-badge__identity">
                <span class="blog-author-badge__label"><%= t('blog.by', 'By') %></span>
                <span class="blog-author-badge__name"><%= post.author_name %></span>
              </div>
              <% if (post.author_position) { %>
                <p class="blog-author-badge__position"><%= post.author_position %></p>
              <% } %>
              <% if (post.author_phone || post.author_email) { %>
                <div class="blog-author-badge__contacts">
                  <% if (post.author_phone) { %>
                    <a class="blog-author-badge__contact" href="tel:<%= authorPhoneHref %>">
                      <%= post.author_phone %>
                    </a>
                  <% } %>
                  <% if (post.author_email) { %>
                    <a class="blog-author-badge__contact" href="mailto:<%= post.author_email %>">
                      <%= post.author_email %>
                    </a>
                  <% } %>
                </div>
              <% } %>
            </div>
          </aside>
        <% } %>
        <% if ((postTopicIds || []).length > 0) { %>
          <div class="post-topics">
            <% postTopicIds.forEach(topicId => { %>
              <a
                class="topic-chip subtle"
                href="<%= ((typeof localePath === 'function') ? localePath('/blog') : '/blog') + '?topic=' + encodeURIComponent(topicId) %>"
              >
                <%= t('blog.topics.' + topicId, topicId) %>
              </a>
            <% }) %>
          </div>
        <% } %>
        <% if (post.cover_image) { %>
          <img src="<%= post.cover_image %>" alt="<%= post.title %>" class="cover" />
        <% } %>
      </header>
      <section class="content">
        <%- post.content %>
      </section>
      <% if ((relatedLandingLinks || []).length > 0) { %>
        <section class="blog-related-landings" aria-label="<%= t('blog.detail.relatedLandingTitle', 'Relevant pages') %>">
          <h2><%= t('blog.detail.relatedLandingTitle', 'Relevant pages') %></h2>
          <p class="blog-related-landings__intro">
            <%= t(
              'blog.detail.relatedLandingIntro',
              'Explore these relevant pages to compare apartments for sale by city and neighborhood.'
            ) %>
          </p>
          <ul class="blog-related-landings__list">
            <% relatedLandingLinks.forEach(function(link) { %>
              <li>
                <a href="<%= link.href %>"><%= link.label %></a>
              </li>
            <% }) %>
          </ul>
        </section>
      <% } %>
    </div>
  </div>
</article>

