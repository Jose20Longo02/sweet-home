<% 
  if (typeof title === 'undefined' || !title) { title = t('nav.blog','Blog'); }
  headPartial = '../partials/seo/blog-list-head';
%>
<link rel="stylesheet" href="/css/blog.css" />
<div class="container main blog-page">
  <h1><%= t('nav.blog','Blog') %></h1>
  <% if ((availableTopics || []).length > 0) { %>
    <nav class="blog-topics" aria-label="<%= t('blog.list.topicsLabel','Blog topics') %>">
      <a class="topic-chip <%= !activeTopic ? 'active' : '' %>" href="<%= (typeof localePath === 'function') ? localePath('/blog') : '/blog' %>">
        <%= t('blog.list.allTopics','All topics') %>
      </a>
      <% availableTopics.forEach(topicId => { %>
        <a
          class="topic-chip <%= activeTopic === topicId ? 'active' : '' %>"
          href="<%= ((typeof localePath === 'function') ? localePath('/blog') : '/blog') + '?topic=' + encodeURIComponent(topicId) %>"
        >
          <%= t('blog.topics.' + topicId, topicId) %>
        </a>
      <% }) %>
    </nav>
  <% } %>
  <% if (activeTopic) { %>
    <section class="blog-topic-intro" aria-label="<%= t('blog.list.topicIntroLabel','Topic overview') %>">
      <h2><%= t('blog.topicIntro.' + activeTopic + '.title', t('blog.topics.' + activeTopic, activeTopic)) %></h2>
      <p><%= t('blog.topicIntro.' + activeTopic + '.body', t('blog.list.topicIntroFallback','Explore hand-picked articles from our team.')) %></p>
    </section>
  <% } %>
  <div class="blog-list">
    <% if ((posts || []).length === 0) { %>
      <p><%= t('blog.list.empty','No articles yet.') %></p>
    <% } %>
    <% (posts || []).forEach(p => { %>
      <article class="blog-card">
        <% if (p.cover_image) { %>
          <img src="<%= p.cover_image %>" alt="<%= p.title || 'Blog post cover image' %>" class="cover" />
        <% } %>
        <div class="info">
          <h2><a href="<%= (typeof localePath === 'function') ? localePath('/blog/' + p.slug) : '/blog/' + p.slug %>"><%= p.title %></a></h2>
          <% if (p.author_name) { %><p class="meta"><%= t('blog.by','By') %> <%= p.author_name %></p><% } %>
          <% if (p.excerpt) { %><p><%= p.excerpt %></p><% } %>
          <% if ((p.topicIds || []).length > 0) { %>
            <div class="post-topics">
              <% p.topicIds.slice(0, 3).forEach(topicId => { %>
                <a
                  class="topic-chip subtle"
                  href="<%= ((typeof localePath === 'function') ? localePath('/blog') : '/blog') + '?topic=' + encodeURIComponent(topicId) %>"
                >
                  <%= t('blog.topics.' + topicId, topicId) %>
                </a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
  <% if (totalPages && totalPages > 1) { %>
    <% const topicSuffix = activeTopic ? ('&topic=' + encodeURIComponent(activeTopic)) : ''; %>
    <% const topicSuffixFirst = activeTopic ? ('?topic=' + encodeURIComponent(activeTopic)) : ''; %>
    <nav class="pagination" aria-label="Pagination">
      <ul>
        <li class="prev <%= page <= 1 ? 'disabled' : '' %>">
          <% if (page <= 1) { %>
            <span><%= t('common.previous','Previous') %></span>
          <% } else { %>
            <% const prevPage = page - 1; %>
            <a href="<%= (typeof localePath === 'function' ? localePath('/blog') : '/blog') + (prevPage > 1 ? ('?page=' + prevPage + topicSuffix) : topicSuffixFirst) %>"><%= t('common.previous','Previous') %></a>
          <% } %>
        </li>
        <% for (var i = 1; i <= totalPages; i++) { %>
          <li class="<%= i === page ? 'active' : '' %>"><a href="<%= (typeof localePath === 'function') ? localePath('/blog') : '/blog' %><%= i > 1 ? ('?page=' + i + topicSuffix) : topicSuffixFirst %>"><%= i %></a></li>
        <% } %>
        <li class="next <%= page >= totalPages ? 'disabled' : '' %>">
          <% if (page >= totalPages) { %>
            <span><%= t('common.next','Next') %></span>
          <% } else { %>
            <a href="<%= (typeof localePath === 'function' ? localePath('/blog') : '/blog') + '?page=' + (page + 1) + topicSuffix %>"><%= t('common.next','Next') %></a>
          <% } %>
        </li>
      </ul>
    </nav>
  <% } %>
  </div>

