<%
  const siteBaseUrl = ((typeof baseUrl !== 'undefined' && baseUrl) ? baseUrl : (process.env.APP_URL || 'https://sweethome.com')).replace(/\/$/, '');
  const contactUrl = `${siteBaseUrl}/contact`;
  const currentLang = (typeof lang !== 'undefined' && lang) ? String(lang).toLowerCase() : 'en';
  const tFn = (typeof t === 'function') ? t : ((k, fb) => fb);
  const pageDesc = (typeof pageMetaDescription !== 'undefined' && pageMetaDescription)
    ? pageMetaDescription
    : tFn('contact.metaDescription', 'Contact Sweet Home for expert real estate services in Berlin, Dubai, and Cyprus. Get in touch for property inquiries and investment opportunities.');
  const pageOgLocale = (typeof ogLocale !== 'undefined' && ogLocale)
    ? ogLocale
    : (currentLang === 'de' ? 'de_DE' : (currentLang === 'es' ? 'es_ES' : 'en_US'));
%>
<meta name="description" content="<%= pageDesc %>">
<link rel="canonical" href="<%= contactUrl %>">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Contact Us - Sweet Home' %>">
<meta property="og:description" content="<%= pageDesc %>">
<meta property="og:url" content="<%= contactUrl %>">
<meta property="og:site_name" content="Sweet Home">
<meta property="og:locale" content="<%= pageOgLocale %>">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'Contact Us - Sweet Home' %>">
<meta name="twitter:description" content="<%= pageDesc %>">
