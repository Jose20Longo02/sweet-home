<%
  const siteBaseUrl = ((typeof baseUrl !== 'undefined' && baseUrl) ? baseUrl : (process.env.APP_URL || 'https://sweethome.com')).replace(/\/$/, '');
  const pageDesc = (typeof seoDescription !== 'undefined' && seoDescription)
    ? seoDescription
    : 'Browse property listings in Berlin, Dubai, and Cyprus with prices, photos, and location details.';
  const pageTitle = (typeof seoTitle !== 'undefined' && seoTitle) ? seoTitle : (typeof title !== 'undefined' ? title : 'Property Search Results');
  const pageUrl = (typeof canonicalUrl !== 'undefined' && canonicalUrl)
    ? canonicalUrl
    : `${siteBaseUrl}/properties`;
  const robotsContent = (typeof robotsMeta !== 'undefined' && robotsMeta) ? robotsMeta : 'index,follow';
  const ogLocale = (typeof lang !== 'undefined' && lang === 'de')
    ? 'de_DE'
    : ((typeof lang !== 'undefined' && lang === 'es') ? 'es_ES' : 'en_US');
%>
<meta name="description" content="<%= pageDesc %>">
<meta name="robots" content="<%= robotsContent %>">

<% if (typeof prevPageUrl !== 'undefined' && prevPageUrl) { %>
<link rel="prev" href="<%= prevPageUrl %>">
<% } %>
<% if (typeof nextPageUrl !== 'undefined' && nextPageUrl) { %>
<link rel="next" href="<%= nextPageUrl %>">
<% } %>

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="<%= pageTitle %> | Sweet Home">
<meta property="og:description" content="<%= pageDesc %>">
<meta property="og:url" content="<%= pageUrl %>">
<meta property="og:site_name" content="Sweet Home">
<meta property="og:locale" content="<%= ogLocale %>">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= pageTitle %> | Sweet Home">
<meta name="twitter:description" content="<%= pageDesc %>">

<!-- JSON-LD ItemList -->
<script type="application/ld+json"><%- (typeof minifyJSON !== 'undefined' ? minifyJSON({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: pageTitle,
  numberOfItems: (typeof seoItemList !== 'undefined' && Array.isArray(seoItemList)) ? seoItemList.length : 0,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: (typeof seoItemList !== 'undefined' && Array.isArray(seoItemList) ? seoItemList : []).map((p, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'RealEstateListing',
      name: p.title || '',
      url: `${siteBaseUrl}/properties/${p.slug}`,
      address: {
        '@type': 'PostalAddress',
        addressLocality: p.city || '',
        addressCountry: p.country || ''
      }
    }
  }))
}) : JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: pageTitle,
  numberOfItems: (typeof seoItemList !== 'undefined' && Array.isArray(seoItemList)) ? seoItemList.length : 0,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: (typeof seoItemList !== 'undefined' && Array.isArray(seoItemList) ? seoItemList : []).map((p, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'RealEstateListing',
      name: p.title || '',
      url: `${siteBaseUrl}/properties/${p.slug}`,
      address: {
        '@type': 'PostalAddress',
        addressLocality: p.city || '',
        addressCountry: p.country || ''
      }
    }
  }))
})) %></script>

