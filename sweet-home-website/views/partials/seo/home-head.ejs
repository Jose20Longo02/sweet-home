<%
  const resolvedBaseUrl = ((typeof baseUrl !== 'undefined' && baseUrl)
    ? String(baseUrl)
    : (process.env.APP_URL || 'https://sweethome.com')).replace(/\/$/, '');
  const siteName = 'Sweet Home';
  const currentLang = (typeof lang !== 'undefined' && lang) ? String(lang).toLowerCase() : 'en';
  const tFn = (typeof t === 'function') ? t : ((k, fb) => fb);
  const defaultDescriptions = {
    de: 'Finden Sie ausgewählte Anlageimmobilien in Berlin, Dubai und Zypern. Sweet Home begleitet internationale Käufer von der Suche bis zum Erwerb.',
    en: 'Find carefully selected investment properties in Berlin, Dubai, and Cyprus. Sweet Home guides international buyers from sourcing to acquisition.',
    es: 'Encuentra propiedades de inversión seleccionadas en Berlín, Dubái y Chipre. Sweet Home acompaña a compradores internacionales de la búsqueda a la adquisición.'
  };
  const resolvedMetaDescription = (typeof pageMetaDescription !== 'undefined' && pageMetaDescription)
    ? pageMetaDescription
    : tFn('home.metaDescription', defaultDescriptions[currentLang] || defaultDescriptions.en);
  const pageOgLocale = (typeof ogLocale !== 'undefined' && ogLocale)
    ? ogLocale
    : (currentLang === 'de' ? 'de_DE' : (currentLang === 'es' ? 'es_ES' : 'en_US'));
  const rawHomeTitle = (typeof title !== 'undefined' && title) ? String(title).trim() : '';
  const homeOgTitle = rawHomeTitle
    ? (/\| Sweet Home$/i.test(rawHomeTitle) ? rawHomeTitle : (rawHomeTitle + ' | Sweet Home'))
    : 'International Real Estate Investment Company | Sweet Home';
  const homeOgUrl = (typeof canonicalUrl !== 'undefined' && canonicalUrl)
    ? canonicalUrl
    : (resolvedBaseUrl + (currentLang === 'en' ? '/en' : (currentLang === 'es' ? '/es' : '/')));
%>
<meta name="description" content="<%= resolvedMetaDescription %>">
<!-- Canonical URL is handled by main layout to avoid conflicts with hreflang -->

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="<%= homeOgTitle %>">
<meta property="og:description" content="<%= resolvedMetaDescription %>">
<meta property="og:url" content="<%= homeOgUrl %>">
<meta property="og:image" content="<%= resolvedBaseUrl %>/images/dubai-hero.jpg">
<meta property="og:site_name" content="<%= siteName %>">
<meta property="og:locale" content="<%= pageOgLocale %>">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= homeOgTitle %>">
<meta name="twitter:description" content="<%= resolvedMetaDescription %>">
<meta name="twitter:image" content="<%= resolvedBaseUrl %>/images/dubai-hero.jpg">

<!-- Organization and WebSite entities share stable IDs across all language versions. -->
<%
  const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${resolvedBaseUrl}/#organization`,
      name: siteName,
      legalName: 'Sweet Home Real Estate Investments',
      url: resolvedBaseUrl,
      logo: {
        '@type': 'ImageObject',
        '@id': `${resolvedBaseUrl}/#logo`,
        url: `${resolvedBaseUrl}/images/Sweet%20Home%20Logo.png`,
        contentUrl: `${resolvedBaseUrl}/images/Sweet%20Home%20Logo.png`,
        caption: siteName
      },
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Hohenzollerndamm 196',
        postalCode: '10717',
        addressLocality: 'Berlin',
        addressCountry: 'DE'
      },
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+49-30-65852933',
        contactType: 'customer service',
        availableLanguage: ['de', 'en', 'es']
      },
      sameAs: [
        'https://www.facebook.com/profile.php?id=100093168151239',
        'https://www.instagram.com/sweet.home.investments/',
        'https://www.linkedin.com/company/sweet-home/'
      ]
    },
    {
      '@type': 'WebSite',
      '@id': `${resolvedBaseUrl}/#website`,
      name: siteName,
      url: resolvedBaseUrl,
      publisher: {
        '@id': `${resolvedBaseUrl}/#organization`
      },
      inLanguage: ['de-DE', 'en-US', 'es-ES'],
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${resolvedBaseUrl}/properties?q={search_term_string}`
        },
        'query-input': 'required name=search_term_string'
      }
    }
  ]
  };
%>
<script type="application/ld+json"><%- (typeof minifyJSON !== 'undefined' ? minifyJSON(homeSchema) : JSON.stringify(homeSchema)) %></script>
