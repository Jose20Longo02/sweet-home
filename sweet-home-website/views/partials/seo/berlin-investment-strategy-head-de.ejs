<%
  const siteBaseUrl = ((typeof baseUrl !== 'undefined' && baseUrl) ? baseUrl : (process.env.APP_URL || 'https://sweethome.com')).replace(/\/$/, '');
  const pagePath = '/berlin-mieter-belegte-einstiegsstrategie';
  const pageUrl = `${siteBaseUrl}${pagePath}`;
  const pageTitleRaw = (typeof title !== 'undefined' && title) ? String(title).trim() : 'Berliner Einstiegsstrategie mit vermieteten Wohnungen';
  const pageTitle = /\| Sweet Home$/i.test(pageTitleRaw) ? pageTitleRaw : (pageTitleRaw + ' | Sweet Home');
  const pageDesc = (typeof pageMetaDescription !== 'undefined' && pageMetaDescription)
    ? pageMetaDescription
    : 'Berliner Einstiegsstrategie mit vermieteten Wohnungen von Sweet Home: strukturierter Zugang mit sofortiger Miettransparenz und langfristigem Potenzial.';
%>
<meta name="description" content="<%= pageDesc %>">

<meta property="og:type" content="website">
<meta property="og:title" content="<%= pageTitle %>">
<meta property="og:description" content="<%= pageDesc %>">
<meta property="og:url" content="<%= (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : pageUrl %>">
<meta property="og:image" content="<%= siteBaseUrl %>/images/berlin-hero.jpg">
<meta property="og:image:alt" content="Berliner Einstiegsstrategie mit vermieteten Wohnungen">
<meta property="og:site_name" content="Sweet Home">
<meta property="og:locale" content="de_DE">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= pageTitle %>">
<meta name="twitter:description" content="<%= pageDesc %>">
<meta name="twitter:image" content="<%= siteBaseUrl %>/images/berlin-hero.jpg">

<script type="application/ld+json"><%- (typeof minifyJSON !== 'undefined' ? minifyJSON({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': pageUrl + '#webpage',
      url: (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : pageUrl,
      name: pageTitle,
      description: pageDesc,
      inLanguage: 'de',
      isPartOf: { '@type': 'WebSite', '@id': siteBaseUrl + '/#website', name: 'Sweet Home' }
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Startseite', item: siteBaseUrl + '/' },
        { '@type': 'ListItem', position: 2, name: 'Berliner Einstiegsstrategie mit vermieteten Wohnungen', item: (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : pageUrl }
      ]
    }
  ]
}) : JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': pageUrl + '#webpage',
      url: (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : pageUrl,
      name: pageTitle,
      description: pageDesc,
      inLanguage: 'de',
      isPartOf: { '@type': 'WebSite', '@id': siteBaseUrl + '/#website', name: 'Sweet Home' }
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Startseite', item: siteBaseUrl + '/' },
        { '@type': 'ListItem', position: 2, name: 'Berliner Einstiegsstrategie mit vermieteten Wohnungen', item: (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : pageUrl }
      ]
    }
  ]
})) %></script>
