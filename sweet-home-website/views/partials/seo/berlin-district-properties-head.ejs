<%
  const siteBaseUrl = ((typeof baseUrl !== 'undefined' && baseUrl) ? baseUrl : (process.env.APP_URL || 'https://sweethome.com')).replace(/\/$/, '');
  const pageUrl = (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : `${siteBaseUrl}/de`;
  const pageDesc = (typeof pageMetaDescription !== 'undefined' && pageMetaDescription) ? pageMetaDescription : 'Eigentumswohnungen in Berlin entdecken.';
  const pageTitle = (typeof title !== 'undefined' && title) ? title : 'Wohnungen in Berlin';
  const districtName = (typeof districtDisplayName !== 'undefined' && districtDisplayName) ? districtDisplayName : 'Berlin';
  const pageFaq = (typeof districtContent !== 'undefined' && districtContent && Array.isArray(districtContent.faq)) ? districtContent.faq : [];
%>
<meta name="description" content="<%= pageDesc %>">
<meta property="og:type" content="website">
<meta property="og:title" content="<%= pageTitle %> | Sweet Home">
<meta property="og:description" content="<%= pageDesc %>">
<meta property="og:url" content="<%= pageUrl %>">
<meta property="og:image" content="<%= siteBaseUrl %>/images/berlin-hero.jpg">
<meta property="og:image:alt" content="<%= districtName %> – Wohnungen in Berlin">
<meta property="og:site_name" content="Sweet Home">
<meta property="og:locale" content="de_DE">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= pageTitle %> | Sweet Home">
<meta name="twitter:description" content="<%= pageDesc %>">
<meta name="twitter:image" content="<%= siteBaseUrl %>/images/berlin-hero.jpg">

<script type="application/ld+json"><%- (typeof minifyJSON !== 'undefined' ? minifyJSON({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': pageUrl + '#webpage',
      name: pageTitle + ' | Sweet Home',
      description: pageDesc,
      url: pageUrl,
      isPartOf: { '@type': 'WebSite', '@id': siteBaseUrl + '/#website', name: 'Sweet Home' }
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Startseite', item: siteBaseUrl + '/de' },
        { '@type': 'ListItem', position: 2, name: 'Wohnungen in Berlin', item: siteBaseUrl + '/de/wohnungen-berlin-kaufen' },
        { '@type': 'ListItem', position: 3, name: districtName, item: pageUrl }
      ]
    }
  ]
}) : JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': pageUrl + '#webpage',
      name: pageTitle + ' | Sweet Home',
      description: pageDesc,
      url: pageUrl,
      isPartOf: { '@type': 'WebSite', '@id': siteBaseUrl + '/#website', name: 'Sweet Home' }
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Startseite', item: siteBaseUrl + '/de' },
        { '@type': 'ListItem', position: 2, name: 'Wohnungen in Berlin', item: siteBaseUrl + '/de/wohnungen-berlin-kaufen' },
        { '@type': 'ListItem', position: 3, name: districtName, item: pageUrl }
      ]
    }
  ]
})) %></script>

<% if (pageFaq.length > 0) { %>
<script type="application/ld+json"><%- (typeof minifyJSON !== 'undefined' ? minifyJSON({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageFaq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
}) : JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageFaq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
})) %></script>
<% } %>
