<%
  const isObject = (v) => v && typeof v === 'object';
  const currentPathSafe = (typeof currentPath === 'string' && currentPath) ? currentPath : '/';
  const isPrivilegedPath = /^\/(admin|superadmin|auth|api)(\/|$)/.test(currentPathSafe);
  const stripLocalePrefix = (p) => String(p || '/').replace(/^\/(en|es)(?=\/|$)/, '') || '/';
  const normalizedCurrentPath = stripLocalePrefix(currentPathSafe);
  const defaultAlternatePaths = {
    de: normalizedCurrentPath === '/' ? '/' : normalizedCurrentPath,
    en: normalizedCurrentPath === '/' ? '/en' : `/en${normalizedCurrentPath}`,
    es: normalizedCurrentPath === '/' ? '/es' : `/es${normalizedCurrentPath}`
  };
  const mergedAlternatePaths = (isObject(localeAlternatePaths) ? localeAlternatePaths : defaultAlternatePaths);
  const encodedAlternatePaths = JSON.stringify(mergedAlternatePaths).replace(/"/g, '&quot;');
  const resolveHrefForLang = (code) => {
    if (isPrivilegedPath) return `/lang/${code}`;
    if (isObject(mergedAlternatePaths) && mergedAlternatePaths[code]) return mergedAlternatePaths[code];
    return defaultAlternatePaths[code] || (code === 'de' ? '/' : `/${code}`);
  };
%>
<div class="lang-switcher" data-alt-paths="<%- encodedAlternatePaths %>">
  <button type="button" class="lang-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="lang-menu">
    <span class="lang-icon" aria-hidden="true">
      <%= (function(){
        var code = (lang || 'de').toLowerCase();
        if (code === 'es') return '🇪🇸';
        if (code === 'de') return '🇩🇪';
        return '🇬🇧';
      })() %>
    </span>
    <span class="lang-current"><%= (languageLabels && languageLabels[lang]) || (lang || 'de').toUpperCase() %></span>
  </button>
  <div id="lang-menu" class="lang-menu" role="menu" aria-hidden="true">
    <% (supportedLanguages || ['en','es','de']).forEach(function(code){ %>
      <a
        role="menuitem"
        class="lang-option <%= (lang===code ? 'is-active' : '') %>"
        data-lang-code="<%= code %>"
        href="<%= resolveHrefForLang(code) %>">
        <%= (languageLabels && languageLabels[code]) || code.toUpperCase() %>
      </a>
    <% }) %>
  </div>
</div>

<style>
  .lang-switcher { position: relative; display: inline-flex; align-items: center; margin-left: 10px; z-index: 1100; }
  .lang-trigger { display: inline-flex; align-items: center; gap: 8px; padding: 8px 12px; border: none; border-radius: 999px; background: transparent; color: #111; font-size: 13px; line-height: 1.2; cursor: pointer; box-shadow: none; transition: transform var(--transition-fast), background-color var(--transition-fast), color var(--transition-fast); }
  .lang-trigger:hover { transform: translateY(-1px); background: rgba(17,17,17,0.04); }
  .lang-trigger:focus-visible { outline: 2px solid var(--primary-light); outline-offset: 2px; }
  .site-header.dark .lang-trigger { background: transparent; color: #fff; }
  .site-header.dark .lang-trigger:hover { background: rgba(255,255,255,0.10); }
  .lang-icon { font-size: 16px; }
  .lang-menu { position: absolute; top: calc(100% + 8px); right: 0; z-index: 1100; min-width: 160px; background: #fff; border: 1px solid var(--gray-200); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); padding: 6px; display: none; }
  .lang-menu.open { display: block !important; }
  .site-header.dark .lang-menu { background: rgba(255,255,255,0.98); border-color: rgba(255,255,255,0.3); }
  .lang-option { display: block; padding: 8px 10px; border-radius: var(--radius-md); text-decoration: none; color: #111; font-size: 13px; }
  .lang-option:hover { background: var(--gray-100); }
  .lang-option.is-active { background: var(--primary-light); color: #fff; }
  .site-header.dark .lang-option:hover { background: rgba(0,0,0,0.06); }
  @media (max-width: 900px) {
    .lang-trigger { padding: 6px 10px; font-size: 12px; }
    .lang-menu { left: 0; right: auto; min-width: 140px; z-index: 1100; }
    .lang-option { padding: 6px 8px; font-size: 12px; }
  }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
</style>

<script>
(function () {
  var switcher = document.querySelector('.lang-switcher');
  if (!switcher) return;
  var path = window.location && window.location.pathname ? window.location.pathname : '/';
  if (/^\/(admin|superadmin|auth|api)(\/|$)/.test(path)) return;

  var search = window.location && window.location.search ? window.location.search : '';
  var hash = window.location && window.location.hash ? window.location.hash : '';

  var serverAlt = {};
  try {
    serverAlt = JSON.parse(switcher.getAttribute('data-alt-paths') || '{}');
  } catch (_) {
    serverAlt = {};
  }

  var normalized = path.replace(/^\/(en|es)(?=\/|$)/, '') || '/';
  var fallbackAlt = {
    de: normalized === '/' ? '/' : normalized,
    en: normalized === '/' ? '/en' : '/en' + normalized,
    es: normalized === '/' ? '/es' : '/es' + normalized
  };

  var options = switcher.querySelectorAll('.lang-option[data-lang-code]');
  options.forEach(function (option) {
    var code = option.getAttribute('data-lang-code');
    if (!code) return;
    var basePath = (serverAlt && serverAlt[code]) ? serverAlt[code] : fallbackAlt[code];
    if (!basePath) return;
    option.setAttribute('href', basePath + search + hash);
  });
})();
</script>


