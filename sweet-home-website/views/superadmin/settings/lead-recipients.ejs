<% title = 'Lead Recipient Settings' %>
<% activePage = 'settings-leads' %>

<link rel="stylesheet" href="/css/superadmin/super-admin-dashboard.css" />

<div class="admin-panel">
  <div class="admin-body">
    <%- include('../../partials/superadmin-sidebar', {
      activePage: 'settings-leads',
      pendingCount: typeof pendingCount !== 'undefined' ? pendingCount : 0
    }) %>

    <main class="admin-content">
      <header class="dashboard-header">
        <div>
          <h1>Lead Recipient Settings</h1>
          <p class="subtitle">Control exactly who gets lead notification emails for each lead source.</p>
        </div>
      </header>

      <% if (message) { %>
        <div class="alert alert-success" style="margin: 1rem 0; padding: 0.9rem 1rem; background: #d1fae5; border: 1px solid #10b981; border-radius: 8px; color: #065f46;">
          <strong>Saved:</strong> <%= message %>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="alert alert-error" style="margin: 1rem 0; padding: 0.9rem 1rem; background: #fee2e2; border: 1px solid #ef4444; border-radius: 8px; color: #991b1b;">
          <strong>Error:</strong> <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/superadmin/dashboard/settings/lead-recipients" style="display: grid; gap: 1rem; max-width: 980px;">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <% const zapierAgents = (teamMembers || []).filter(function (member) { return member && member.bmby_id; }); %>

        <%
          function renderRecipientPicker(fieldName, selectedEmails, requiredAtLeastOne) {
            const values = (Array.isArray(selectedEmails) && selectedEmails.length)
              ? selectedEmails
              : [''];
        %>
          <div
            class="recipient-picker"
            data-picker
            data-field-name="<%= fieldName %>"
            data-required="<%= requiredAtLeastOne ? 'true' : 'false' %>"
            style="display: grid; gap: 0.55rem;"
          >
            <% values.forEach(function(emailValue, idx) { %>
              <div class="recipient-row" data-recipient-row style="display: flex; gap: 0.55rem; align-items: center;">
                <select
                  name="<%= fieldName %>"
                  style="flex: 1; border: 1px solid #d1d5db; border-radius: 8px; padding: 0.55rem; font: inherit;"
                  <%= (requiredAtLeastOne && idx === 0) ? 'required' : '' %>
                >
                  <option value="">Select team member</option>
                  <% (teamMembers || []).forEach(function(member) { %>
                    <option value="<%= member.email %>" <%= String(member.email).toLowerCase() === String(emailValue || '').toLowerCase() ? 'selected' : '' %>>
                      <%= member.name %> (<%= member.email %>)
                    </option>
                  <% }); %>
                </select>
                <button
                  type="button"
                  data-remove-recipient
                  style="border: 1px solid #d1d5db; background: #fff; color: #374151; border-radius: 8px; padding: 0.5rem 0.65rem; cursor: pointer;"
                  aria-label="Remove recipient"
                >Remove</button>
              </div>
            <% }); %>
            <button
              type="button"
              data-add-recipient
              style="justify-self: start; border: 1px solid #10b981; color: #047857; background: #ecfdf5; border-radius: 8px; padding: 0.45rem 0.75rem; cursor: pointer; font-weight: 600;"
            >+ Add recipient</button>
          </div>
        <% } %>

        <section style="background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.1rem;">
          <h3 style="margin: 0 0 0.35rem; color: #111827;">Property page forms</h3>
          <p style="margin: 0 0 0.9rem; color: #4b5563; font-size: 0.92rem;">
            Default: send to the <strong>agent in charge</strong>. You can also add backup recipients.
          </p>
          <label style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 0.8rem; color: #111827;">
            <input type="checkbox" name="property_notify_assigned_agent" <%= settings.property_form && settings.property_form.notifyAssignedAgent ? 'checked' : '' %> />
            Notify assigned property agent
          </label>
          <label style="display: block; margin: 0 0 0.4rem; color: #374151; font-weight: 600;">Additional recipients (optional)</label>
          <% renderRecipientPicker('property_recipient_emails', settings.property_form && settings.property_form.recipientEmails, false); %>
        </section>

        <section style="background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.1rem;">
          <h3 style="margin: 0 0 0.35rem; color: #111827;">Project page forms</h3>
          <p style="margin: 0 0 0.9rem; color: #4b5563; font-size: 0.92rem;">
            Default: send to the <strong>agent in charge</strong>. You can also add backup recipients.
          </p>
          <label style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 0.8rem; color: #111827;">
            <input type="checkbox" name="project_notify_assigned_agent" <%= settings.project_form && settings.project_form.notifyAssignedAgent ? 'checked' : '' %> />
            Notify assigned project agent
          </label>
          <label style="display: block; margin: 0 0 0.4rem; color: #374151; font-weight: 600;">Additional recipients (optional)</label>
          <% renderRecipientPicker('project_recipient_emails', settings.project_form && settings.project_form.recipientEmails, false); %>
        </section>

        <section style="background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.1rem;">
          <h3 style="margin: 0 0 0.35rem; color: #111827;">Contact form</h3>
          <p style="margin: 0 0 0.9rem; color: #4b5563; font-size: 0.92rem;">
            Default recipients: <strong><%= (defaults.contact_form.recipientEmails || []).join(', ') %></strong>.
          </p>
          <label style="display: block; margin: 0 0 0.4rem; color: #374151; font-weight: 600;">Recipients</label>
          <% renderRecipientPicker('contact_recipient_emails', settings.contact_form && settings.contact_form.recipientEmails, true); %>
          <label style="display: block; margin: 0.8rem 0 0.35rem; color: #374151; font-weight: 600;">Zapier BMBy Agent</label>
          <select
            name="contact_zapier_agent_id"
            style="width: 100%; border: 1px solid #d1d5db; border-radius: 8px; padding: 0.55rem; font: inherit;"
          >
            <option value="">Fallback default (Israel)</option>
            <% zapierAgents.forEach(function(agent) { %>
              <option value="<%= agent.id %>" <%= Number(settings.contact_form && settings.contact_form.zapierDefaultAgentId) === Number(agent.id) ? 'selected' : '' %>>
                <%= agent.name %> - BMBy: <%= agent.bmby_id %>
              </option>
            <% }); %>
          </select>
        </section>

        <section style="background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.1rem;">
          <h3 style="margin: 0 0 0.35rem; color: #111827;">Seller form</h3>
          <p style="margin: 0 0 0.9rem; color: #4b5563; font-size: 0.92rem;">
            Default recipients: <strong><%= (defaults.seller_form.recipientEmails || []).join(', ') %></strong>.
          </p>
          <label style="display: block; margin: 0 0 0.4rem; color: #374151; font-weight: 600;">Recipients</label>
          <% renderRecipientPicker('seller_recipient_emails', settings.seller_form && settings.seller_form.recipientEmails, true); %>
          <label style="display: block; margin: 0.8rem 0 0.35rem; color: #374151; font-weight: 600;">Zapier BMBy Agent</label>
          <select
            name="seller_zapier_agent_id"
            style="width: 100%; border: 1px solid #d1d5db; border-radius: 8px; padding: 0.55rem; font: inherit;"
          >
            <option value="">Fallback default (Israel)</option>
            <% zapierAgents.forEach(function(agent) { %>
              <option value="<%= agent.id %>" <%= Number(settings.seller_form && settings.seller_form.zapierDefaultAgentId) === Number(agent.id) ? 'selected' : '' %>>
                <%= agent.name %> - BMBy: <%= agent.bmby_id %>
              </option>
            <% }); %>
          </select>
        </section>

        <section style="background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.1rem;">
          <h3 style="margin: 0 0 0.35rem; color: #111827;">Berlin investor strategy form</h3>
          <p style="margin: 0 0 0.9rem; color: #4b5563; font-size: 0.92rem;">
            Default recipients: <strong><%= (defaults.berlin_investor_strategy_form.recipientEmails || []).join(', ') %></strong>.
          </p>
          <label style="display: block; margin: 0 0 0.4rem; color: #374151; font-weight: 600;">Recipients</label>
          <% renderRecipientPicker('berlin_strategy_recipient_emails', settings.berlin_investor_strategy_form && settings.berlin_investor_strategy_form.recipientEmails, true); %>
          <label style="display: block; margin: 0.8rem 0 0.35rem; color: #374151; font-weight: 600;">Zapier BMBy Agent</label>
          <select
            name="berlin_strategy_zapier_agent_id"
            style="width: 100%; border: 1px solid #d1d5db; border-radius: 8px; padding: 0.55rem; font: inherit;"
          >
            <option value="">Fallback default (Israel)</option>
            <% zapierAgents.forEach(function(agent) { %>
              <option value="<%= agent.id %>" <%= Number(settings.berlin_investor_strategy_form && settings.berlin_investor_strategy_form.zapierDefaultAgentId) === Number(agent.id) ? 'selected' : '' %>>
                <%= agent.name %> - BMBy: <%= agent.bmby_id %>
              </option>
            <% }); %>
          </select>
        </section>

        <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-top: 0.2rem;">
          <p style="margin: 0; color: #6b7280; font-size: 0.86rem;">
            Changes apply immediately to new lead notifications.
          </p>
          <button type="submit" class="btn btn-primary" style="min-width: 220px;">Save lead recipient settings</button>
        </div>
      </form>
    </main>
  </div>
</div>

<script>
  (function () {
    var pickers = document.querySelectorAll('[data-picker]');
    if (!pickers.length) return;

    function updateRemoveButtons(picker) {
      var rows = picker.querySelectorAll('[data-recipient-row]');
      var requiresOne = picker.getAttribute('data-required') === 'true';
      rows.forEach(function (row) {
        var removeBtn = row.querySelector('[data-remove-recipient]');
        if (!removeBtn) return;
        removeBtn.disabled = rows.length <= 1;
        removeBtn.style.opacity = rows.length <= 1 ? '0.45' : '1';
      });
      rows.forEach(function (row, idx) {
        var select = row.querySelector('select');
        if (!select) return;
        select.required = requiresOne && idx === 0;
      });
    }

    pickers.forEach(function (picker) {
      var addBtn = picker.querySelector('[data-add-recipient]');
      if (!addBtn) return;

      addBtn.addEventListener('click', function () {
        var firstRow = picker.querySelector('[data-recipient-row]');
        if (!firstRow) return;
        var clone = firstRow.cloneNode(true);
        var select = clone.querySelector('select');
        if (select) {
          select.value = '';
          select.required = false;
        }
        picker.insertBefore(clone, addBtn);
        updateRemoveButtons(picker);
      });

      picker.addEventListener('click', function (event) {
        var removeBtn = event.target.closest('[data-remove-recipient]');
        if (!removeBtn) return;
        var row = removeBtn.closest('[data-recipient-row]');
        if (!row) return;
        var rows = picker.querySelectorAll('[data-recipient-row]');
        if (rows.length <= 1) return;
        row.remove();
        updateRemoveButtons(picker);
      });

      updateRemoveButtons(picker);
    });
  })();
</script>
